<UserControl x:Class="WPF_Student_Management.Components.EmployeeDetailDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:WPF_Student_Management.Helpers"
             mc:Ignorable="d">

    <Border CornerRadius="16" Background="White" Margin="10" MinWidth="800" MaxWidth="800" MinHeight="550" MaxHeight="650">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2" />
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Thông tin Nhân viên" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                        Foreground="Gray" Width="30" Height="30" Padding="0" Margin="0,-5,-5,0">
                    <materialDesign:PackIcon Kind="Close" Width="22" Height="22" />
                </Button>
            </Grid>

            <Border Grid.Row="1" Background="White" CornerRadius="20" BorderBrush="#E5E7EB" BorderThickness="1.5" Padding="30,25,30,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Rectangle Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="2" Fill="#F0F0F0" Margin="0,10" />

                    <StackPanel Grid.Column="0" Margin="10,0,30,0">
                        <Label Content="Thông tin cơ bản" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="#FF1A237E" />

                        <Label Content="Họ Tên: *" FontWeight="SemiBold" FontSize="14" Foreground="Gray" />
                        <Border Background="#F8F9FA" CornerRadius="8" BorderBrush="#D2D6DC" BorderThickness="1" Margin="0,2,0,12" Height="40">
                            <TextBox Text="{Binding CurrentStaff.FullName, UpdateSourceTrigger=PropertyChanged}" 
                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                     BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0" FontSize="15" />
                        </Border>

                        <Label Content="Giới tính:" FontWeight="SemiBold" FontSize="14" Foreground="Gray" />

                        <ComboBox ItemsSource="{Binding GenderList}" SelectedItem="{Binding CurrentStaff.Gender}" 
                                        materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                        BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0" FontSize="15" />

                        <Label Content="CCCD/CMND: *" FontWeight="SemiBold" FontSize="14" Foreground="Gray" />
                        <Border Background="#F8F9FA" CornerRadius="8" BorderBrush="#D2D6DC" BorderThickness="1" Margin="0,2,0,12" Height="40">
                            <TextBox Text="{Binding CurrentStaff.NationalId, UpdateSourceTrigger=PropertyChanged}" 
                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                     BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0" FontSize="15" />
                        </Border>

                        <Label Content="Chuyên môn:" FontWeight="SemiBold" FontSize="14" Foreground="Gray" />
                        <Border Background="#F8F9FA" CornerRadius="8" BorderBrush="#D2D6DC" BorderThickness="1" Margin="0,2,0,12" Height="40">
                            <TextBox Text="{Binding CurrentStaff.Specialization, UpdateSourceTrigger=PropertyChanged}" 
                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                     BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0" FontSize="15" />
                        </Border>

                        <Label Content="Vai trò / Quyền hạn:" FontWeight="SemiBold" FontSize="14" Foreground="Gray" />
                        
                            <ComboBox ItemsSource="{Binding RoleList}" 
                                        SelectedValue="{Binding CurrentStaff.RoleId}"
                                        SelectedValuePath="RoleId"
                                        DisplayMemberPath="RoleName"
                                        materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                        BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0" FontSize="15" />
                      
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="30,0,10,0">
                        <Label Content="Liên lạc &amp; Công tác" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="#FF1A237E" />

                        <Label Content="Số điện thoại: *" FontWeight="SemiBold" FontSize="14" Foreground="Gray" />
                        <Border Background="#F8F9FA" CornerRadius="8" BorderBrush="#D2D6DC" BorderThickness="1" Margin="0,2,0,12" Height="40">
                            <TextBox Text="{Binding CurrentStaff.PhoneNumber, UpdateSourceTrigger=PropertyChanged}" 
                                     helpers:TextBoxHelper.IsNumericOnly="True" MaxLength="10" 
                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                     BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0" FontSize="15" />
                        </Border>

                        <Label Content="Email: *" FontWeight="SemiBold" FontSize="14" Foreground="Gray" />
                        <Border Background="#F8F9FA" CornerRadius="8" BorderBrush="#D2D6DC" BorderThickness="1" Margin="0,2,0,12" Height="40">
                            <TextBox Text="{Binding CurrentStaff.Email, UpdateSourceTrigger=PropertyChanged}" 
                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                     BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0" FontSize="15" />
                        </Border>

                        <Label Content="Địa chỉ:" FontWeight="SemiBold" FontSize="14" Foreground="Gray" />
                        <Border Background="#F8F9FA" CornerRadius="8" BorderBrush="#D2D6DC" BorderThickness="1" Margin="0,2,0,12" Height="40">
                            <TextBox Text="{Binding CurrentStaff.HometownAddress, UpdateSourceTrigger=PropertyChanged}" 
                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                     BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0" FontSize="15" />
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Label Content="Ngày vào làm:" FontWeight="SemiBold" FontSize="14" Foreground="Gray" />
                                <Border Background="#F8F9FA" CornerRadius="8" BorderBrush="#D2D6DC" BorderThickness="1" Margin="0,2,0,12" Height="40">
                                    <DatePicker SelectedDate="{Binding CurrentStaff.HireDate}" 
                                                materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                                BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0" FontSize="15" />
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Label Content="Trạng thái:" FontWeight="SemiBold" FontSize="14" Foreground="Gray" />

                                <ComboBox ItemsSource="{Binding StatusList}" SelectedItem="{Binding CurrentStaff.Status}" 
                                                materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                                BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0" FontSize="15" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- FOOTER BUTTONS -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">

                <Button Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" 
                        IsCancel="True"
                        Content="Hủy" 
                        Width="100" 
                        Height="40" 
                        Margin="0,0,15,0" 
                        Style="{StaticResource OutlineRoundedButton}" 
                        BorderThickness="2" 
                        Cursor="Hand" />

                <Button Command="{Binding SaveCommand}" 
                        IsDefault="True"
                        Content="Lưu nhân viên" 
                        Width="160"
                        Height="40" 
                        Style="{StaticResource PrimaryRoundedButton}" 
                        Cursor="Hand" />

            </StackPanel>
        </Grid>
    </Border>
</UserControl>