<UserControl x:Class="WPF_Student_Management.Components.GradeEntryUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Components"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="1000"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:WPF_Student_Management.Helpers"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

    <Grid VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Color="#DDDDDD"
                                  Opacity="0.5" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                    <StackPanel Grid.Column="0"
                                Margin="0,0,20,0">
                        <TextBlock Text="Môn học:"
                                   FontWeight="Bold"
                                   Margin="0,0,0,5"
                                   Foreground="Black"
                                   FontSize="14" />
                        <ComboBox Height="35"
                                  Width="220"
                                  ItemsSource="{Binding Subjects}"
                                  SelectedItem="{Binding SelectedSubject}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="0,0,20,0">
                        <TextBlock Text="Lớp:"
                                   FontWeight="Bold"
                                   Margin="0,0,0,5"
                                   Foreground="Black"
                                   FontSize="14" />
                        <ComboBox Height="35"
                                  Width="150"
                                  ItemsSource="{Binding Classes}"
                                  SelectedItem="{Binding SelectedClass}" />
                    </StackPanel>
                </StackPanel>

                <Button Content="Lấy danh sách"
                        Grid.Column="2"
                        Margin="5,0,0,0"
                        Command="{Binding LoadGradeDataCommand}"
                        Style="{StaticResource PrimaryRoundedButton}"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Right">
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="20"
                VerticalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Color="#DDDDDD"
                                  Opacity="0.5" />
            </Border.Effect>

            <Grid VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="0,0,0,15">
                    <TextBlock Text="{Binding GradebookTitle}"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="Black" />

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,15,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSaveVisible}"
                                                     Value="Collapsed">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <materialDesign:PackIcon Kind="Lock"
                                                     Foreground="#D32F2F"
                                                     Width="20"
                                                     Height="20"
                                                     Margin="0,0,5,0"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="ĐIỂM ĐÃ BỊ KHÓA"
                                       Foreground="#D32F2F"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <Button Content="Lưu bảng điểm"
                                Visibility="{Binding IsSaveVisible}"
                                Background="#00B894"
                                Height="40"
                                Width="155"
                                Command="{Binding SaveGradeDataCommand}"
                                Style="{StaticResource PrimaryRoundedButton}">
                        </Button>
                    </StackPanel>
                </Grid>

                <DataGrid Grid.Row="1"
                          AutoGenerateColumns="False"
                          ItemsSource="{Binding StudentGrades}"
                          helpers:DataGridHelper.EnableFastEntry="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          VerticalAlignment="Stretch"
                          HorizontalAlignment="Stretch"
                          Style="{StaticResource GlobalDataGridStyle}"
                          CellStyle="{StaticResource GlobalDataGridCellStyle}"
                          FontSize="15"
                          IsReadOnly="{Binding IsGradebookReadOnly}">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="STT"
                                            Binding="{Binding OrdinalNumber}"
                                            IsReadOnly="True"
                                            Width="60"
                                            HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                            ElementStyle="{StaticResource GlobalCenterElementStyle}" />

                        <DataGridTextColumn Header="Họ và tên"
                                            Binding="{Binding FullName}"
                                            IsReadOnly="True"
                                            Width="*"
                                            HeaderStyle="{StaticResource GlobalLeftHeaderStyle}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"
                                       BasedOn="{StaticResource GlobalLeftElementStyle}">
                                    <Setter Property="FontWeight"
                                            Value="SemiBold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Điểm Thường xuyên"
                                            Binding="{Binding RegularScore, UpdateSourceTrigger=LostFocus, TargetNullValue=''}"
                                            IsReadOnly="False"
                                            Width="175"
                                            HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                            ElementStyle="{StaticResource GlobalCenterElementStyle}">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="helpers:TextBoxHelper.IsBgdGradeOnly"
                                            Value="True" />
                                    <Setter Property="helpers:TextBoxHelper.SelectAllOnFocus"
                                            Value="True" />
                                    <Setter Property="HorizontalContentAlignment"
                                            Value="Center" />
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Điểm Giữa kỳ"
                                            Binding="{Binding MidSemScore, UpdateSourceTrigger=LostFocus, TargetNullValue=''}"
                                            IsReadOnly="False"
                                            Width="130"
                                            HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                            ElementStyle="{StaticResource GlobalCenterElementStyle}">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="helpers:TextBoxHelper.IsBgdGradeOnly"
                                            Value="True" />
                                    <Setter Property="helpers:TextBoxHelper.SelectAllOnFocus"
                                            Value="True" />
                                    <Setter Property="HorizontalContentAlignment"
                                            Value="Center" />
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Điểm Cuối kỳ"
                                            Binding="{Binding FinalScore, UpdateSourceTrigger=LostFocus, TargetNullValue=''}"
                                            IsReadOnly="False"
                                            Width="130"
                                            HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                            ElementStyle="{StaticResource GlobalCenterElementStyle}">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="helpers:TextBoxHelper.IsBgdGradeOnly"
                                            Value="True" />
                                    <Setter Property="helpers:TextBoxHelper.SelectAllOnFocus"
                                            Value="True" />
                                    <Setter Property="HorizontalContentAlignment"
                                            Value="Center" />
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Trung bình"
                                            Binding="{Binding AverageScore, StringFormat={}{0:F1}}"
                                            IsReadOnly="True"
                                            Width="110"
                                            HeaderStyle="{StaticResource GlobalCenterHeaderStyle}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"
                                       BasedOn="{StaticResource GlobalCenterElementStyle}">
                                    <Setter Property="Foreground"
                                            Value="Gray" />
                                    <Setter Property="FontWeight"
                                            Value="SemiBold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Border>
    </Grid>
</UserControl>