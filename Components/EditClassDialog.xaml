<UserControl x:Class="WPF_Student_Management.Components.EditClassDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Components"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:WPF_Student_Management.Helpers"
             mc:Ignorable="d"
             Width="450"
             Height="Auto">

    <Border Background="White"
            CornerRadius="15"
            Padding="25">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Sửa thông tin lớp học"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#1A237E"
                       Margin="0,0,0,20" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      Margin="0,0,15,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Khối lớp"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"
                               Foreground="#333"
                               FontSize="14" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  SelectedValue="{Binding Grade}"
                                  SelectedValuePath="Content"
                                  HorizontalAlignment="Stretch"
                                  Height="50"
                                  FontSize="15"
                                  IsEnabled="False">
                            <ComboBoxItem Content="10" />
                            <ComboBoxItem Content="11" />
                            <ComboBoxItem Content="12" />
                        </ComboBox>
                    </Grid>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Tên lớp học"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"
                               Foreground="#333"
                               FontSize="14" />
                    <Border Grid.Row="1"
                            BorderBrush="#89000000"
                            BorderThickness="1"
                            CornerRadius="12"
                            Height="50">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding Grade}"
                                       VerticalAlignment="Center"
                                       Padding="12,0,5,0"
                                       FontSize="16"
                                       Foreground="#1A237E"
                                       FontWeight="Bold" />

                            <TextBox Grid.Column="1"
                                     Text="{Binding NewClassName, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                     materialDesign:HintAssist.Hint="A1, Tin, Lý..."
                                     helpers:TextBoxHelper.IsAlphaNumericOnly="True"
                                     Padding="0,0,10,0"
                                     FontSize="15"
                                     VerticalContentAlignment="Center">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return"
                                                Command="{Binding SaveClassCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <TextBlock Grid.Row="2"
                       Text="Giáo viên chủ nhiệm"
                       FontWeight="SemiBold"
                       Margin="0,20,0,8"
                       Foreground="#333"
                       FontSize="14" />

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding AvailableTeachers}"
                          SelectedItem="{Binding SelectedTeacher}"
                          DisplayMemberPath="FullName"
                          materialDesign:HintAssist.Hint="Chọn giáo viên (Không bắt buộc)"
                          HorizontalAlignment="Stretch"
                          Height="50"
                          FontSize="15" />
            </Grid>

            <Border Grid.Row="4"
                    Background="#F0F2F5"
                    CornerRadius="8"
                    Padding="15"
                    Margin="0,20,0,25">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                             Foreground="#1A73E8"
                                             VerticalAlignment="Center"
                                             Width="30"
                                             Height="30" />
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="Lưu ý quy định:"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Foreground="#555"
                                   Padding="3" />
                        <TextBlock Text="- Tên lớp phải bắt đầu bằng tiền tố Khối lớp đã chọn."
                                   FontSize="13"
                                   Foreground="#666" />
                        <TextBlock Text="- Lớp sau khi lập sẽ có trạng thái 'Rỗng' (Sĩ số = 0)."
                                   FontSize="13"
                                   Foreground="#666" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="5"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Hủy bỏ"
                        Command="{Binding CancelEditClassCommand}"
                        Style="{StaticResource OutlineRoundedButton}"
                        IsCancel="True"
                        Width="100"
                        Margin="0,0,10,0"
                        Height="40" />

                <Button Content="Lưu"
                        Command="{Binding SaveEditClassCommand}"
                        Style="{StaticResource PrimaryRoundedButton}"
                        IsDefault="True"
                        Width="120"
                        Height="40" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
