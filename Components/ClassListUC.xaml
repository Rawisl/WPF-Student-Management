<UserControl x:Class="WPF_Student_Management.Components.ClassListUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Components"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <DataGrid HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              ItemsSource="{Binding ClassList}"
              Style="{StaticResource GlobalDataGridStyle}"
              CellStyle="{StaticResource GlobalDataGridCellStyle}"
              FontSize="15">

        <DataGrid.Columns>
            <DataGridTextColumn Header="Mã lớp"
                                Binding="{Binding ClassId}"
                                Width="60"
                                IsReadOnly="True"
                                HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                ElementStyle="{StaticResource GlobalCenterElementStyle}">
            </DataGridTextColumn>

            <DataGridTextColumn Header="Khối"
                                Binding="{Binding Grade}"
                                Width="100"
                                IsReadOnly="True"
                                HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                ElementStyle="{StaticResource GlobalCenterElementStyle}">
            </DataGridTextColumn>

            <DataGridTextColumn Header="Tên lớp"
                                Binding="{Binding DisplayClassName}"
                                Width="*"
                                IsReadOnly="True"
                                HeaderStyle="{StaticResource GlobalLeftHeaderStyle}"
                                >
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock"
                           BasedOn="{StaticResource GlobalLeftElementStyle}">
                        <Setter Property="FontWeight"
                                Value="SemiBold" />
                    </Style>
                </DataGridTextColumn.ElementStyle>

            </DataGridTextColumn>

            <DataGridTextColumn Header="GVCN"
                                Binding="{Binding HomeroomTeacherName}"
                                Width="150"
                                IsReadOnly="True"
                                HeaderStyle="{StaticResource GlobalLeftHeaderStyle}">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock"
                           BasedOn="{StaticResource GlobalLeftElementStyle}">
                        <Setter Property="FontWeight"
                                Value="SemiBold" />
                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Header="Trạng thái"
                                Binding="{Binding StatusText}"
                                Width="150"
                                IsReadOnly="True"
                                HeaderStyle="{StaticResource GlobalCenterHeaderStyle}">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock"
                           BasedOn="{StaticResource GlobalCenterElementStyle}">

                        <Setter Property="Foreground"
                                Value="#00B894" />
                        <Setter Property="FontWeight"
                                Value="SemiBold" />

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusText}"
                                         Value="Đầy">
                                <Setter Property="Foreground"
                                        Value="#FF4757" />
                            </DataTrigger>
                        </Style.Triggers>

                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTemplateColumn Header="Thao Tác"
                                    Width="120"
                                    HeaderStyle="{StaticResource GlobalCenterHeaderStyle}">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Hidden" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                                                     Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <Button Command="{Binding DataContext.OpenEditClassDialogCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Foreground="#00B894"
                                    Background="Transparent"
                                    Style="{StaticResource MaterialDesignIconForegroundButton}"
                                    BorderThickness="0"
                                    Width="35"
                                    Height="35"
                                    Margin="0,0,10,0"
                                    Padding="0"
                                    Cursor="Hand"
                                    ToolTip="Sửa thông tin">
                                <materialDesign:PackIcon Kind="PencilOutline"
                                                         Width="22"
                                                         Height="22"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Button>

                            <Button Command="{Binding DataContext.DeleteClassCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource MaterialDesignIconForegroundButton}"
                                    Foreground="#FF4757"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Width="35"
                                    Height="35"
                                    Padding="0"
                                    Cursor="Hand"
                                    ToolTip="Xóa học sinh">
                                <materialDesign:PackIcon Kind="TrashCanOutline"
                                                         Width="22"
                                                         Height="22"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Button>
                        </StackPanel>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
        </DataGrid.Columns>


    </DataGrid>
</UserControl>

