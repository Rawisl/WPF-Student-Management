<UserControl x:Class="WPF_Student_Management.Components.SubjectReportUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Components"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Báo cáo môn học"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20" />

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Color="#DDDDDD"
                                  Opacity="0.5" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.7*" />
                    <ColumnDefinition Width="0.7*" />
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="0.9*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="0,0,20,0">
                    <TextBlock Text="Năm học:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"
                               Foreground="Gray" />
                    <ComboBox Height="35"
                              ItemsSource="{Binding DanhSachNamHocReport}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="0,0,20,0">
                    <TextBlock Text="Học kỳ:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"
                               Foreground="Gray" />
                    <ComboBox Height="35"
                              ItemsSource="{Binding DanhSachHocKyReport}" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Margin="0,0,20,0">
                    <TextBlock Text="Môn học:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"
                               Foreground="Gray" />
                    <ComboBox Height="35"
                              ItemsSource="{Binding DanhSachMonReport}" />
                </StackPanel>

                <StackPanel Grid.Column="3"
                            Margin="0,0,20,0">
                    <TextBlock Text="Lớp:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"
                               Foreground="Gray" />
                    <ComboBox Height="35"
                              ItemsSource="{Binding DanhSachHocKyReport}" />
                </StackPanel>

                <Button Content="Xem Báo Cáo"
                        Grid.Column="4"
                        Margin="5,0,0,0"
                        Command="{Binding GenerateReportCommand}"
                        Style="{StaticResource PrimaryRoundedButton}"
                        VerticalAlignment="Bottom">
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Color="#DDDDDD"
                                  Opacity="0.5" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Thống kê theo lớp"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,15" />

                <DataGrid Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Background="Transparent"
                          BorderThickness="0"
                          RowHeight="40"
                          ItemsSource="{Binding ReportData}"
                          SelectedItem="{Binding SelectedReportRow}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT"
                                            Binding="{Binding STT}"
                                            IsReadOnly="True"
                                            Width="60" />
                        <DataGridTextColumn Header="Lớp"
                                            Binding="{Binding TenLop}"
                                            IsReadOnly="True"
                                            Width="*" />
                        <DataGridTextColumn Header="Sĩ số"
                                            Binding="{Binding SiSo}"
                                            IsReadOnly="True"
                                            Width="100" />
                        <DataGridTextColumn Header="Số lượng Đạt"
                                            Binding="{Binding SoLuongDat}"
                                            IsReadOnly="True"
                                            Width="120" />
                        <DataGridTextColumn Header="Tỷ lệ (%)"
                                            Binding="{Binding TyLeDat, StringFormat={}{0:F2}%}"
                                            IsReadOnly="True"
                                            Width="120"
                                            Foreground="Green"
                                            FontWeight="Bold" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="White"
                CornerRadius="8"
                Padding="20"
                Margin="0,10,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Color="#DDDDDD"
                                  Opacity="0.5" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding SelectedReportRow.TenLop, StringFormat='Danh sách chi tiết lớp: {0}'}"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,15" />

                <DataGrid Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Background="Transparent"
                          BorderThickness="0"
                          RowHeight="40"
                          ItemsSource="{Binding DanhSachHocSinhChiTiet}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT"
                                            Binding="{Binding STT}"
                                            IsReadOnly="True"
                                            Width="60" />
                        <DataGridTextColumn Header="Họ và tên"
                                            Binding="{Binding HoTen}"
                                            IsReadOnly="True"
                                            Width="*" />
                        <DataGridTextColumn Header="Điểm TB"
                                            Binding="{Binding DiemTB}"
                                            IsReadOnly="True"
                                            Width="100" />
                        <DataGridTextColumn Header="Kết quả"
                                            Binding="{Binding KetQua}"
                                            IsReadOnly="True"
                                            Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
