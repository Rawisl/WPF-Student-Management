<UserControl x:Class="WPF_Student_Management.Components.StudentProfileUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Components"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    
    <DataGrid HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
              Style="{StaticResource GlobalDataGridStyle}"
              CellStyle="{StaticResource GlobalDataGridCellStyle}"
              FontSize="15">

        <DataGrid.Columns>
            <DataGridTextColumn Header="Mã học sinh"
                                Binding="{Binding StudentId}"
                                Width="100"
                                IsReadOnly="True"
                                HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                ElementStyle="{StaticResource GlobalCenterElementStyle}">
            </DataGridTextColumn>

            <DataGridTextColumn Header="Họ và Tên"
                                Binding="{Binding FullName}"
                                Width="*"
                                IsReadOnly="True"
                                HeaderStyle="{StaticResource GlobalLeftHeaderStyle}">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock"
                           BasedOn="{StaticResource GlobalLeftElementStyle}">
                        <Setter Property="FontWeight"
                                Value="SemiBold" />
                    </Style>
                </DataGridTextColumn.ElementStyle>

            </DataGridTextColumn>

            <DataGridTextColumn Header="Giới tính"
                                Binding="{Binding Gender}"
                                Width="100"
                                IsReadOnly="True"
                                HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                ElementStyle="{StaticResource GlobalCenterElementStyle}">
            </DataGridTextColumn>

            <DataGridTextColumn Header="Ngày Sinh"
                                Binding="{Binding DateOfBirth, StringFormat=dd/MM/yyyy}"
                                Width="150"
                                IsReadOnly="True"
                                Foreground="Gray"
                                HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                ElementStyle="{StaticResource GlobalCenterElementStyle}">
            </DataGridTextColumn>

            <DataGridTextColumn Header="SĐT"
                                Binding="{Binding PhoneNumber}"
                                Width="120"
                                IsReadOnly="True"
                                HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                ElementStyle="{StaticResource GlobalCenterElementStyle}">
            </DataGridTextColumn>

            <DataGridTemplateColumn x:Name="colAction"
                                    Header="Thao Tác"
                                    Width="120"
                                    HeaderStyle="{StaticResource GlobalCenterHeaderStyle}">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Hidden" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                                                     Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <Button Command="{Binding EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Foreground="#00B894"
                                    Background="Transparent"
                                    Style="{StaticResource MaterialDesignIconForegroundButton}"
                                    BorderThickness="0"
                                    Width="35"
                                    Height="35"
                                    Margin="0,0,10,0"
                                    Padding="0"
                                    Cursor="Hand"
                                    ToolTip="Sửa thông tin">
                                <materialDesign:PackIcon Kind="PencilOutline"
                                                         Width="22"
                                                         Height="22"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Button>

                            <Button Command="{Binding DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Foreground="#FF4757"
                                    Background="Transparent"
                                    Style="{StaticResource MaterialDesignIconForegroundButton}"
                                    BorderThickness="0"
                                    Width="35"
                                    Height="35"
                                    Padding="0"
                                    Cursor="Hand"
                                    ToolTip="Xóa học sinh">
                                <materialDesign:PackIcon Kind="TrashCanOutline"
                                                         Width="22"
                                                         Height="22"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Button>
                        </StackPanel>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
        </DataGrid.Columns>
    </DataGrid>
</UserControl>