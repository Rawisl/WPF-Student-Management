<UserControl x:Class="WPF_Student_Management.Components.StudentProfileDetailUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:WPF_Student_Management.Components"
             mc:Ignorable="d"
             d:DesignHeight="625"
             d:DesignWidth="450">
    
    <Border Background="White"
            CornerRadius="15"
            Padding="25">
        <StackPanel>
            <TextBlock Text="CẬP NHẬT HỒ SƠ"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#FF1A237E"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center" />

            <Label Content="Mã Học Sinh:"
                   FontWeight="SemiBold"
                   FontSize="14"
                   Foreground="Gray" />
            <Border Background="#F5F5F5"
                    CornerRadius="8"
                    BorderBrush="#D2D6DC"
                    BorderThickness="1"
                    Margin="0,5,0,15"
                    Height="40">
                <TextBox Text="{Binding StudentID}"
                         BorderThickness="0"
                         Background="Transparent"
                         IsReadOnly="True"
                         Foreground="Gray"
                         VerticalContentAlignment="Center"
                         Padding="10,0"
                         FontSize="15" />
            </Border>

            <Label Content="Họ Tên:"
                   FontWeight="SemiBold"
                   FontSize="14"
                   Foreground="Gray" />
            <Border Background="#F8F9FA"
                    CornerRadius="8"
                    BorderBrush="#D2D6DC"
                    BorderThickness="1"
                    Margin="0,5,0,15"
                    Height="40">
                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="0"
                         Background="Transparent"
                         VerticalContentAlignment="Center"
                         Padding="10,0"
                         FontSize="15" />
            </Border>

            <Label Content="Giới tính:"
                   FontWeight="SemiBold"
                   FontSize="14"
                   Foreground="Gray" />
            <Border Background="#F8F9FA"
                    CornerRadius="8"
                    BorderBrush="#D2D6DC"
                    BorderThickness="1"
                    Margin="0,5,0,15"
                    Height="40">
                <ComboBox SelectedValue="{Binding Gender}"
                          SelectedValuePath="Content"
                          BorderThickness="0"
                          Background="Transparent"
                          VerticalContentAlignment="Center"
                          Padding="10,0"
                          FontSize="15">
                    <ComboBoxItem Content="Nam" />
                    <ComboBoxItem Content="Nữ" />
                </ComboBox>
            </Border>

            <Label Content="Ngày sinh:"
                   FontWeight="SemiBold"
                   FontSize="14"
                   Foreground="Gray" />
            <Border Background="#F8F9FA"
                    CornerRadius="8"
                    BorderBrush="#D2D6DC"
                    BorderThickness="1"
                    Margin="0,5,0,5"
                    Height="40">
                <DatePicker SelectedDate="{Binding DateOfBirth, UpdateSourceTrigger=PropertyChanged}"
                            BorderThickness="0"
                            Background="Transparent"
                            VerticalContentAlignment="Center"
                            Padding="10,0"
                            FontSize="15" />
            </Border>

            <TextBlock Text="{Binding AgeErrorMessage}"
                       Foreground="Red"
                       FontSize="13"
                       Margin="5,0,0,15"
                       TextWrapping="Wrap"
                       Visibility="{Binding AgeErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

            <Label Content="Địa chỉ:"
                   FontWeight="SemiBold"
                   FontSize="14"
                   Foreground="Gray" />
            <Border Background="#F8F9FA"
                    CornerRadius="8"
                    BorderBrush="#D2D6DC"
                    BorderThickness="1"
                    Margin="0,5,0,20"
                    Height="60">
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="10,5"
                         FontSize="15" />
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Margin="0,0,5,0"
                        Content="HỦY"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource OutlineRoundedButton}"
                        Foreground="Gray"
                        BorderBrush="Gray" />

                <Button Grid.Column="1"
                        Margin="5,0,0,0"
                        Content="LƯU THAY ĐỔI"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryRoundedButton}">
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>