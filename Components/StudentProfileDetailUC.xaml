<UserControl x:Class="WPF_Student_Management.Components.StudentProfileDetailUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:WPF_Student_Management.Helpers"
             mc:Ignorable="d"
             d:Height="800"
             d:Width="850">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <Border CornerRadius="16"
            Background="White"
            Margin="10"
            MinWidth="800"
            MaxWidth="800"
            MinHeight="650"
            MaxHeight="700">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15"
                              ShadowDepth="3"
                              Opacity="0.2" />
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="CẬP NHẬT HỒ SƠ HỌC SINH"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#FF1A237E"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center" />

            <Border Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="White"
                    CornerRadius="20"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1.5"
                    Padding="30,25,30,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Rectangle Grid.Column="1"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Stretch"
                               Width="2"
                               Fill="#F0F0F0"
                               Margin="0,10" />

                    <StackPanel Grid.Column="0"
                                Margin="10,0,30,0">
                        <Label Content="Thông tin cơ bản"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,15"
                               Foreground="#FF1A237E" />

                        <Label Content="Mã Học Sinh:"
                               FontWeight="SemiBold"
                               FontSize="15"
                               Foreground="#3e4c82" />

                        <Border Background="#F5F5F5"
                                CornerRadius="8"
                                BorderBrush="#D2D6DC"
                                BorderThickness="1"
                                Margin="0,2,0,12"
                                Height="40">
                            <TextBox Text="{Binding StudentID}"
                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     IsReadOnly="True"
                                     Foreground="Black"
                                     FontWeight="SemiBold"
                                     VerticalContentAlignment="Center"
                                     Padding="10,0"
                                     FontSize="15" />
                        </Border>

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,10">
                            <Run Text="Họ Tên"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource RoundedTextBoxStyle}" />

                        <Label Content="Giới tính:"
                               FontWeight="SemiBold"
                               FontSize="15"
                               Foreground="#3e4c82" />
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,2,0,12"
                                    Height="40"
                                    VerticalAlignment="Center">
                            <RadioButton Content="Nam"
                                         IsChecked="{Binding IsMale}"
                                         Margin="0,0,30,0"
                                         FontSize="15" />
                            <RadioButton Content="Nữ"
                                         IsChecked="{Binding IsFemale}"
                                         FontSize="15" />
                        </StackPanel>

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,10">
                            <Run Text="Ngày sinh"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <Border Style="{StaticResource InputWrapperBorderStyle}">
                            <DatePicker SelectedDate="{Binding DateOfBirth, UpdateSourceTrigger=PropertyChanged}"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        VerticalContentAlignment="Center"
                                        Padding="10,0"
                                        FontSize="15" />
                        </Border>

                        <TextBlock Text="{Binding AgeErrorMessage}"
                                   Foreground="#FF4757"
                                   FontWeight="Bold"
                                   Margin="0,5,0,12"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding AgeErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,10">
                            <Run Text="Hoàn cảnh gia đình"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,2,0,12"
                                    Height="40"
                                    VerticalAlignment="Center">
                            <RadioButton Content="Bình thường"
                                         IsChecked="{Binding IsFamilyNormal}"
                                         Margin="0,0,30,0"
                                         FontSize="15" />
                            <RadioButton Content="Khó khăn"
                                         IsChecked="{Binding IsFamilyHard}"
                                         FontSize="15" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Margin="30,0,10,0">
                        <Label Content="Liên lạc"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,15"
                               Foreground="#FF1A237E" />

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,10">
                            <Run Text="SĐT học sinh"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <Border Style="{StaticResource InputWrapperBorderStyle}">
                            <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                     helpers:TextBoxHelper.IsNumericOnly="True"
                                     MaxLength="10"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Padding="10,0"
                                     FontSize="15" />
                        </Border>

                        <Label Content="Email:"
                               FontWeight="SemiBold"
                               FontSize="15"
                               Foreground="#3e4c82" />

                        <Border Style="{StaticResource InputWrapperBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding EmailPrefix, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         VerticalContentAlignment="Center"
                                         Padding="10,0,0,0"
                                         FontSize="15" />
                                <TextBlock Grid.Column="1"
                                           Text="@gmail.com"
                                           VerticalAlignment="Center"
                                           Padding="0,0,10,0"
                                           FontSize="15"
                                           Foreground="#95A5A6"
                                           FontWeight="SemiBold" />
                            </Grid>
                        </Border>

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,10">
                            <Run Text="Địa chỉ"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource RoundedTextBoxStyle}"
                                 VerticalContentAlignment="Top"
                                 Height="70" 
                                 Padding="10,5,0,0"
                                 TextWrapping="Wrap"/>

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,10">
                            <Run Text="Họ tên người bảo hộ"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <TextBox Text="{Binding GuardianName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource RoundedTextBoxStyle}" />

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,5">
                            <Run Text="SĐT người bảo hộ"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <Border Style="{StaticResource InputWrapperBorderStyle}">
                            <TextBox Text="{Binding GuardianPhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     helpers:TextBoxHelper.IsNumericOnly="True"
                                     MaxLength="10"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Padding="10,0"
                                     FontSize="15" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                    <Button Command="{Binding ResetPasswordCommand}"
                            IsEnabled="{Binding IsAccountActive}"
                            Content="CẤP LẠI MẬT KHẨU"
                            ToolTipService.ShowOnDisabled="True"
                            Height="40"
                            Margin="0,0,15,0"
                            Style="{StaticResource OutlineRoundedButton}"
                            Foreground="#D32F2F"
                            BorderBrush="#EF5350">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PasswordReset"
                                                             Margin="0,0,8,0"
                                                             VerticalAlignment="Center"
                                                             Width="18"
                                                             Height="18" />
                                    <TextBlock Text="CẤP LẠI MẬT KHẨU"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <Button Command="{Binding OpenRequestFormCommand}"
                            Visibility="{Binding IsCreateRequestVisible, Converter={StaticResource BoolToVisConverter}}"
                            Content="LẬP ĐƠN THAY ĐỔI"
                            ToolTip="Lập phiếu yêu cầu chuyển lớp hoặc thôi học cho học sinh này"
                            Height="40"
                            Style="{StaticResource OutlineRoundedButton}"
                            Foreground="#F57C00"
                            BorderBrush="#FFB74D">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileDocumentEditOutline"
                                                             Margin="0,0,8,0"
                                                             VerticalAlignment="Center"
                                                             Width="18"
                                                             Height="18" />
                                    <TextBlock Text="LẬP ĐƠN THAY ĐỔI"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Command="{Binding CancelCommand}"
                            Content="HỦY BỎ"
                            Width="120"
                            Height="40"
                            Margin="0,0,15,0"
                            Style="{StaticResource OutlineRoundedButton}"
                            BorderThickness="2" />
                    <Button Command="{Binding SaveCommand}"
                            Content="LƯU THAY ĐỔI"
                            Width="160"
                            Height="40"
                            Style="{StaticResource PrimaryRoundedButton}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>