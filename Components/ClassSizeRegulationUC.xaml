<UserControl x:Class="WPF_Student_Management.Components.ClassSizeRegulationUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Components"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:WPF_Student_Management.Helpers">

    <materialDesign:Card Margin="0,0,0,20"
                         Padding="20"
                         UniformCornerRadius="20"
                         BorderBrush="Black"
                         BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Quy định về Lớp học"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,15"
                       Foreground="#FF1A237E" />
            <Separator Margin="0,0,0,15"
                       Background="#F0F0F0" />

            <Label Content="Sĩ số tối đa:"
                   Foreground="Black"
                   Margin="0,0,0,5"
                   FontSize="18"
                   FontWeight="Bold" />
            <Border Background="#F3F5F9"
                    CornerRadius="10"
                    Height="45"
                    Width="300"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,20"
                    BorderBrush="#D2D6DC"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtMaxClassSize"
                             Text="{Binding MaxClassSize, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             Padding="15,0"
                             FontSize="16"
                             helpers:TextBoxHelper.IsNumericOnly="True"
                             Grid.Column="0" />
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="0,0,5,0">
                        <Button Command="{Binding IncreaseClassSizeCommand}"
                                Content="▲"
                                Height="18"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="Gray" />
                        <Button Command="{Binding ReduceClassSizeCommand}"
                                Content="▼"
                                Height="18"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="Gray" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,10">
                <TextBlock Text="Cấu hình danh sách lớp:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           FontSize="16" />
                <Button Command="{Binding AddClassCommand}"
                        Content="+ Thêm lớp"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#FF270EDC"
                        FontWeight="Bold"
                        Cursor="Hand" />
            </Grid>

            <DataGrid x:Name="dgClass"
                      ItemsSource="{Binding ClassList}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      Background="White"
                      BorderThickness="1"
                      BorderBrush="#F0F0F0"
                      RowHeight="40"
                      ColumnHeaderHeight="40">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="STT"
                                        Binding="{Binding OrdinalNumber}"
                                        Width="60"
                                        IsReadOnly="True" />
                    <DataGridTemplateColumn Header="Khối"
                                            Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#F3F5F9"
                                        CornerRadius="5"
                                        Margin="2">
                                    <TextBox Text="{Binding Grade, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Padding="5,2" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Tên lớp"
                                            Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#F3F5F9"
                                        CornerRadius="5"
                                        Margin="2">
                                    <TextBox Text="{Binding ClassName, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Padding="5,2" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Xóa"
                                        Binding="{Binding DeleteIcon}"
                                        Width="60"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="Red" />
                                <Setter Property="FontWeight"
                                        Value="Bold" />
                                <Setter Property="HorizontalAlignment"
                                        Value="Center" />
                                <Setter Property="VerticalAlignment"
                                        Value="Center" />
                                <Setter Property="Cursor"
                                        Value="Hand" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </materialDesign:Card>
</UserControl>
