<UserControl x:Class="WPF_Student_Management.Components.RejectReasonDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Components"
             xmlns:helpers="clr-namespace:WPF_Student_Management.Helpers"
             mc:Ignorable="d"
             Width="500"
             Height="345">

    <Border CornerRadius="16"
            Background="White"
            Margin="10"
            Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15"
                              ShadowDepth="3"
                              Opacity="0.2" />
        </Border.Effect>

        <StackPanel>
            <TextBlock Text="XÁC NHẬN TRẢ ĐƠN"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#D32F2F"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20" />

            <TextBlock Text="Vui lòng nhập lý do từ chối thực thi đơn này. Lý do sẽ được lưu lại để GVCN theo dõi."
                       TextWrapping="Wrap"
                       Foreground="#555555"
                       Margin="0,0,0,15" 
                       FontSize="13"/>

            <TextBlock FontSize="14"
                       FontWeight="SemiBold"
                       Margin="5,0,0,5">
                <Run Text="Lý do trả đơn"
                     Foreground="#3e4c82" />
                <Run Text="*"
                     Foreground="#FF4757" />
            </TextBlock>

            <TextBox Text="{Binding RejectReason, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource RoundedTextBoxStyle}"
                     helpers:TextBoxHelper.IsLettersOnly="True"
                     Height="90"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalContentAlignment="Top"
                     Padding="10,10" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,15,0,0">
                <Button Command="{Binding CancelRejectCommand}"
                        Content="HỦY BỎ"
                        Width="100"
                        Height="40"
                        Margin="0,0,10,0"
                        Style="{StaticResource OutlineRoundedButton}" />
                <Button Command="{Binding ConfirmRejectCommand}"
                        Style="{StaticResource PrimaryRoundedButton}"
                        Content="Xác nhận trả đơn"
                        Width="180"
                        Height="40"
                        Background="#FF4757"
                        BorderBrush="#FF4757"
                        Foreground="White" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>