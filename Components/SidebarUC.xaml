<UserControl x:Class="WPF_Student_Management.Components.SidebarUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Components"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="250"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="ModernSidebarMenu"
               TargetType="RadioButton">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#d9e7ff" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Height"
                    Value="45" />
            <Setter Property="Margin"
                    Value="10,2,10,2" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Left" />
            <Setter Property="Padding"
                    Value="15,0,0,0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="GroupName"
                    Value="SidebarMenuGroup" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#3F3F4E" />
                                <Setter Property="Foreground"
                                        Value="White" />
                            </Trigger>

                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#a0aef2" />
                                <Setter Property="Foreground"
                                        Value="White" />
                                <Setter Property="FontWeight"
                                        Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="StPn_Button"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Margin="0,20,0,20">

            <RadioButton Style="{StaticResource ModernSidebarMenu}"
                         IsChecked="True"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{Binding ClassRosterVM}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AccountMultiplePlusOutline"
                                             Width="20"
                                             Height="20"
                                             Margin="0,0,15,0" />
                    <TextBlock Text="Xếp lớp"
                               FontSize="14"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <RadioButton Style="{StaticResource ModernSidebarMenu}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{Binding SubjectGradebookVM}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="BookOpenVariant"
                                             Width="20"
                                             Height="20"
                                             Margin="0,0,15,0" />
                    <TextBlock Text="Sổ điểm môn học"
                               FontSize="14"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <RadioButton Style="{StaticResource ModernSidebarMenu}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{Binding HomeroomDashboardVM}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="GoogleClassroom"
                                             Width="20"
                                             Height="20"
                                             Margin="0,0,15,0" />
                    <TextBlock Text="Lớp chủ nhiệm"
                               FontSize="14"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <Separator Background="#d9e7ff"
                       Margin="20,10,20,10"
                       Height="1"
                       BorderThickness="0" />

            <RadioButton Style="{StaticResource ModernSidebarMenu}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{Binding GlobalStudentManagementVM}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="DatabaseOutline"
                                             Width="20"
                                             Height="20"
                                             Margin="0,0,15,0" />
                    <TextBlock Text="Danh sách học sinh"
                               FontSize="14"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <RadioButton Style="{StaticResource ModernSidebarMenu}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{Binding ClassManagementVM}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Domain"
                                             Width="20"
                                             Height="20"
                                             Margin="0,0,15,0" />
                    <TextBlock Text="Quản lý lớp học"
                               FontSize="14"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <RadioButton Style="{StaticResource ModernSidebarMenu}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{Binding SubjectManagementVM}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="BookEducationOutline"
                                             Width="20"
                                             Height="20"
                                             Margin="0,0,15,0" />
                    <TextBlock Text="Quản lý môn học"
                               FontSize="14"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <RadioButton Style="{StaticResource ModernSidebarMenu}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{Binding EmployeeManagementVM}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="BadgeAccountOutline"
                                             Width="20"
                                             Height="20"
                                             Margin="0,0,15,0" />
                    <TextBlock Text="Quản lý nhân viên"
                               FontSize="14"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <Separator Background="#d9e7ff"
                       Margin="20,10,20,10"
                       Height="1"
                       BorderThickness="0" />

            <RadioButton Style="{StaticResource ModernSidebarMenu}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{Binding EnrollmentChangeExecutionVM}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileDocumentMultipleOutline"
                                             Width="20"
                                             Height="20"
                                             Margin="0,0,15,0" />
                    <TextBlock Text="Xử lý đơn từ"
                               FontSize="14"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <RadioButton Style="{StaticResource ModernSidebarMenu}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{Binding GlobalSummaryReportVM}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileChartOutline"
                                             Width="20"
                                             Height="20"
                                             Margin="0,0,15,0" />
                    <TextBlock Text="Báo cáo tổng kết"
                               FontSize="14"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <RadioButton Style="{StaticResource ModernSidebarMenu}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{Binding GradeLookupVM}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="TextSearch"
                                             Width="20"
                                             Height="20"
                                             Margin="0,0,15,0" />
                    <TextBlock Text="Tra cứu điểm"
                               FontSize="14"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <RadioButton Style="{StaticResource ModernSidebarMenu}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{Binding TeachingAssignmentVM}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CalendarAccountOutline"
                                             Width="20"
                                             Height="20"
                                             Margin="0,0,15,0" />
                    <TextBlock Text="Phân công giảng dạy"
                               FontSize="14"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <Separator Background="#d9e7ff"
                       Margin="20,10,20,10"
                       Height="1"
                       BorderThickness="0" />

            <RadioButton Style="{StaticResource ModernSidebarMenu}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{Binding RegulationSettingsVM}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Gavel"
                                             Width="20"
                                             Height="20"
                                             Margin="0,0,15,0" />
                    <TextBlock Text="Thay đổi quy định"
                               FontSize="14"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <RadioButton Style="{StaticResource ModernSidebarMenu}"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{Binding SettingsVM}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CogOutline"
                                             Width="20"
                                             Height="20"
                                             Margin="0,0,15,0" />
                    <TextBlock Text="Cài đặt"
                               FontSize="14"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

        </StackPanel>
    </ScrollViewer>
</UserControl>