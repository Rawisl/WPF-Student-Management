<UserControl x:Class="WPF_Student_Management.Components.AddStudentDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Components"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"
                             Background="White"
                             UniformCornerRadius="20"
                             Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Rectangle Grid.Column="1"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Stretch"
                           Width="2"
                           Fill="#F0F0F0"
                           Margin="0,10" />

                <StackPanel x:Name="ThongTinSP"
                            Grid.Column="0"
                            Margin="10,0,30,0">
                    <Label Content="Thông tin cơ bản"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,15"
                           Foreground="#FF1A237E" />

                    <Label Content="Họ Tên: *"
                           FontWeight="SemiBold"
                           FontSize="16"
                           Foreground="Gray" />
                    <Border Background="#F8F9FA"
                            CornerRadius="8"
                            BorderBrush="#D2D6DC"
                            BorderThickness="1"
                            Margin="0,5,0,15"
                            Height="40">
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"
                                 FontSize="15" />
                    </Border>

                    <Label Content="Giới tính:"
                           FontWeight="SemiBold"
                           FontSize="16"
                           Foreground="Gray" />
                    <StackPanel Orientation="Horizontal"
                                Margin="0,5,0,15"
                                Height="40"
                                VerticalAlignment="Center">
                        <RadioButton Content="Nam"
                                     IsChecked="{Binding IsMale}"
                                     Margin="0,0,30,0"
                                     FontSize="15" />
                        <RadioButton Content="Nữ"
                                     IsChecked="{Binding IsFemale}"
                                     FontSize="15" />
                    </StackPanel>

                    <Label Content="Ngày sinh:"
                           FontWeight="SemiBold"
                           FontSize="16"
                           Foreground="Gray" />
                    <Border Background="#F8F9FA"
                            CornerRadius="8"
                            BorderBrush="#D2D6DC"
                            BorderThickness="1"
                            Margin="0,5,0,0"
                            Height="40">
                        <DatePicker SelectedDate="{Binding DateOfBirth, UpdateSourceTrigger=PropertyChanged}"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    VerticalContentAlignment="Center"
                                    Padding="10,0"
                                    FontSize="15" />
                    </Border>

                    <TextBlock Text="{Binding AgeErrorMessage}"
                               Foreground="#FF4757"
                               FontWeight="Bold"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel x:Name="LienLacSP"
                            Grid.Column="2"
                            Margin="30,0,10,0">
                    <Label Content="Liên lạc"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,15"
                           Foreground="#FF1A237E" />

                    <Label Content="Địa chỉ: *"
                           FontWeight="SemiBold"
                           FontSize="16"
                           Foreground="Gray" />
                    <Border Background="#F8F9FA"
                            CornerRadius="8"
                            BorderBrush="#D2D6DC"
                            BorderThickness="1"
                            Margin="0,5,0,15"
                            Height="70">
                        <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Padding="10,5"
                                 FontSize="15" />
                    </Border>

                    <Label Content="Email:"
                           FontWeight="SemiBold"
                           FontSize="16"
                           Foreground="Gray" />
                    <Border Background="#F8F9FA"
                            CornerRadius="8"
                            BorderBrush="#D2D6DC"
                            BorderThickness="1"
                            Margin="0,5,0,15"
                            Height="40">
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"
                                 FontSize="15" />
                    </Border>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Command="{Binding CancelCommand}"
                    Content="Hủy"
                    Width="100"
                    Height="40"
                    Margin="0,0,15,0"
                    Background="#95A5A6"
                    BorderBrush="Transparent"
                    Foreground="White"
                    FontSize="16"
                    FontWeight="Bold"
                    Style="{StaticResource OutlineRoundedButton}">
            </Button>

            <Button Command="{Binding SaveCommand}"
                    Content="Lưu học sinh"
                    Width="140"
                    Height="40"
                    Style="{StaticResource PrimaryRoundedButton}"
                    FontWeight="Bold">
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
