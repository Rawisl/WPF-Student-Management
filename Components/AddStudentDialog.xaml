<UserControl x:Class="WPF_Student_Management.Components.AddStudentDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Components"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:Height="650"
             d:Width="850"
             xmlns:helpers="clr-namespace:WPF_Student_Management.Helpers">

    <Border CornerRadius="16"
            Background="White"
            Margin="10"
            MinWidth="800"
            MaxWidth="800"
            MinHeight="650"
            MaxHeight="700">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15"
                              ShadowDepth="3"
                              Opacity="0.2" />
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="20"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1.5"
                    Padding="30,25,30,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Rectangle Grid.Column="1"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Stretch"
                               Width="2"
                               Fill="#F0F0F0"
                               Margin="0,10" />

                    <StackPanel x:Name="ThongTinSP"
                                Grid.Column="0"
                                Margin="10,0,30,0">
                        <Label Content="Thông tin cơ bản"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,10"
                               Foreground="#FF1A237E" />

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,5">
                            <Run Text="Họ Tên"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource RoundedTextBoxStyle}" />

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,5">
                            <Run Text="Giới tính"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,2,0,12"
                                    Height="40"
                                    VerticalAlignment="Center">
                            <RadioButton Content="Nam"
                                         IsChecked="{Binding IsMale}"
                                         Margin="0,0,30,0"
                                         FontSize="15" />
                            <RadioButton Content="Nữ"
                                         IsChecked="{Binding IsFemale}"
                                         FontSize="15" />
                        </StackPanel>

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,5">
                            <Run Text="Ngày sinh"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <Border Style="{StaticResource InputWrapperBorderStyle}">
                            <DatePicker SelectedDate="{Binding DateOfBirth, UpdateSourceTrigger=PropertyChanged}"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        VerticalContentAlignment="Center"
                                        Padding="10,0"
                                        FontSize="15" />
                        </Border>

                        <TextBlock Text="{Binding AgeErrorMessage}"
                                   Foreground="#FF4757"
                                   FontWeight="Bold"
                                   Margin="0,5,0,12"
                                   TextWrapping="Wrap" />

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,5">
                            <Run Text="Hoàn cảnh gia đình"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,2,0,12"
                                    Height="40"
                                    VerticalAlignment="Center">
                            <RadioButton Content="Bình thường"
                                         IsChecked="{Binding IsFamilyNormal}"
                                         Margin="0,0,30,0"
                                         FontSize="15" />
                            <RadioButton Content="Khó khăn"
                                         IsChecked="{Binding IsFamilyHard}"
                                         FontSize="15" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="LienLacSP"
                                Grid.Column="2"
                                Margin="30,0,10,0">
                        <Label Content="Liên lạc"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,10"
                               Foreground="#FF1A237E" />

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,5">
                            <Run Text="SĐT học sinh"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <Border Style="{StaticResource InputWrapperBorderStyle}">
                            <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                     helpers:TextBoxHelper.IsNumericOnly="True"
                                     BorderThickness="0"
                                     MaxLength="10"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Padding="10,0"
                                     FontSize="15" />
                        </Border>
                        <Label Content="Email:"
                               FontWeight="SemiBold"
                               FontSize="15"
                               Foreground="#3e4c82" />

                        <Border Style="{StaticResource InputWrapperBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="164*" />
                                    <ColumnDefinition Width="47*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding EmailPrefix, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         VerticalContentAlignment="Center"
                                         Padding="10,0,0,0"
                                         FontSize="15"
                                         Grid.ColumnSpan="3"
                                         Margin="0,0,95,0" />

                                <TextBlock Grid.Column="2"
                                           Text="@gmail.com"
                                           VerticalAlignment="Center"
                                           Padding="0,0,10,0"
                                           FontSize="15"
                                           Foreground="#95A5A6"
                                           FontWeight="SemiBold" />
                            </Grid>

                        </Border>

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,5">
                            <Run Text="Địa chỉ"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource RoundedTextBoxStyle}"
                                 VerticalContentAlignment="Top"
                                 Height="70"
                                 Padding="10,5,0,0"
                                 TextWrapping="Wrap"/>

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,5">
                            <Run Text="Họ tên người bảo hộ"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <TextBox Text="{Binding GuardianName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource RoundedTextBoxStyle}" />

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,5">
                            <Run Text="SĐT người bảo hộ"
                                 Foreground="#3e4c82" />
                            <Run Text="*"
                                 Foreground="#FF4757" />
                        </TextBlock>

                        <Border Style="{StaticResource InputWrapperBorderStyle}">
                            <TextBox Text="{Binding GuardianPhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     helpers:TextBoxHelper.IsNumericOnly="True"
                                     MaxLength="10"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Padding="10,0"
                                     FontSize="15" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">

                <Button Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Content="Hủy"
                        Width="100"
                        Height="40"
                        Margin="0,0,15,0"
                        Style="{StaticResource OutlineRoundedButton}"
                        BorderThickness="2">
                </Button>

                <Button Command="{Binding SaveCommand}"
                        IsDefault="True"
                        Content="Lưu học sinh"
                        Width="140"
                        Height="40"
                        Style="{StaticResource PrimaryRoundedButton}">
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
