<UserControl x:Class="WPF_Student_Management.Components.CustomTopBarUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="40"
             d:DesignWidth="1200">
    <Grid Background="Transparent"
          MouseLeftButtonDown="TopBar_MouseLeftButtonDown">

        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="15,0,0,0">
            <Image Source="/Images/student-management-logo.ico"
                   Width="22"
                   Height="22"
                   Margin="0,0,10,0"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <TextBlock x:Name="txtTitle"
                       Text="{Binding TitleText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontWeight="Bold"
                       FontSize="15"
                       Foreground="#1A237E" />
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,0,10,0">
            <Button Click="BtnMinimize_Click"
                    Width="30"
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Foreground="Gray"
                    Cursor="Hand"
                    ToolTip="Thu nhỏ">
                <materialDesign:PackIcon Kind="WindowMinimize"
                                         Width="18"
                                         Height="18"
                                         HorizontalAlignment="Center" />
            </Button>

            <Button x:Name="btnMaximize"
                    Click="BtnMaximize_Click"
                    Visibility="{Binding ShowMaximizeButton, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Width="30"
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Foreground="Gray"
                    Cursor="Hand"
                    ToolTip="Thu phóng">
                <materialDesign:PackIcon x:Name="iconMaximize"
                                         Kind="WindowMaximize"
                                         Width="18"
                                         Height="18"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
            </Button>

            <Button Click="BtnClose_Click"
                    Width="30"
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Foreground="#FF4757"
                    Cursor="Hand"
                    ToolTip="Đóng">
                <materialDesign:PackIcon Kind="Close"
                                         Width="20"
                                         Height="20"
                                         HorizontalAlignment="Center" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>