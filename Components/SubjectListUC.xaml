<UserControl x:Class="WPF_Student_Management.Components.SubjectListUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Components"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="1"
                  x:Name="dgSubject"
                  ItemsSource="{Binding SubjectsList}"
                  Style="{StaticResource GlobalDataGridStyle}"
                  CellStyle="{StaticResource GlobalDataGridCellStyle}"
                  FontSize="15">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Mã môn"
                                    Binding="{Binding SubjectId}"
                                    Width="80"
                                    IsReadOnly="True"
                                    HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                    ElementStyle="{StaticResource GlobalCenterElementStyle}">
                </DataGridTextColumn>

                <DataGridTextColumn Header="Tên môn học"
                                    Binding="{Binding SubjectName}"
                                    Width="*"
                                    IsReadOnly="True"
                                    HeaderStyle="{StaticResource GlobalLeftHeaderStyle}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"
                               BasedOn="{StaticResource GlobalLeftElementStyle}">
                            <Setter Property="FontWeight"
                                    Value="SemiBold" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Loại điểm"
                                    Binding="{Binding GradeType, Converter={StaticResource GradeTypeConverter}}"
                                    Width="250"
                                    IsReadOnly="True"
                                    HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                    ElementStyle="{StaticResource GlobalCenterElementStyle}">
                </DataGridTextColumn>


                <DataGridTemplateColumn x:Name="colAction"
                                        Header="Thao Tác"
                                        Width="100"
                                        HeaderStyle="{StaticResource GlobalCenterHeaderStyle}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility"
                                                Value="Hidden" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                                                         Value="True">
                                                <Setter Property="Visibility"
                                                        Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <Button Command="{Binding DataContext.DeleteSubjectCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                                        Foreground="#FF4757"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Width="35"
                                        Height="35"
                                        Padding="0"
                                        Cursor="Hand"
                                        ToolTip="Xóa môn học">
                                    <materialDesign:PackIcon Kind="TrashCanOutline"
                                                             Width="22"
                                                             Height="22"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</UserControl>
