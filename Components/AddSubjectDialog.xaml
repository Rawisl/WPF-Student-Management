<UserControl x:Class="WPF_Student_Management.Components.AddSubjectDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Components"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:WPF_Student_Management.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="900">

    <Border CornerRadius="16"
            Background="White"
            Margin="10"
            MinWidth="450"
            MaxWidth="450"
            MinHeight="290"
            MaxHeight="290">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15"
                              ShadowDepth="3"
                              Opacity="0.2" />
        </Border.Effect>

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="THÊM MÔN HỌC MỚI"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#1A237E"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20" />

            <TextBox Grid.Row="1"
                     materialDesign:HintAssist.Hint="Tên môn học *"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     helpers:TextBoxHelper.IsAlphaNumericOnly="True"
                     Text="{Binding NewSubjectName, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="16"
                     Margin="0,0,0,20" />

            <TextBlock Grid.Row="2"
                       Text="Loại điểm (Không thể sửa sau khi tạo):"
                       FontSize="14"
                       Foreground="Gray"
                       Margin="0,0,0,10" />

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        Margin="0,0,0,30"
                        HorizontalAlignment="Center">
                <RadioButton Content="Thang điểm (1 - 10)"
                             IsChecked="{Binding IsScoreGradeType}"
                             Style="{StaticResource MaterialDesignDarkRadioButton}"
                             Foreground="#1A237E"
                             FontWeight="SemiBold"
                             FontSize="15"
                             Margin="0,0,30,0" />

                <RadioButton Content="Đạt / Không đạt"
                             IsChecked="{Binding IsPassFailGradeType}"
                             Style="{StaticResource MaterialDesignDarkRadioButton}"
                             Foreground="#1A237E"
                             FontWeight="SemiBold"
                             FontSize="15" />
            </StackPanel>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Hủy bỏ"
                        Command="{Binding CancelAddSubjectCommand}"
                        IsCancel="True"
                        Style="{StaticResource OutlineRoundedButton}"
                        FontSize="14"
                        Width="90"
                        Margin="0,0,15,0" />

                <Button Content="Lưu môn"
                        Command="{Binding SaveSubjectCommand}"
                        Style="{StaticResource PrimaryRoundedButton}"
                        IsDefault="True"
                        FontSize="14"
                        Width="90" />
            </StackPanel>
        </Grid>

    </Border>

</UserControl>
