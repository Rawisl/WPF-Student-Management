<UserControl x:Class="WPF_Student_Management.Components.EnrollmentChangeRequestUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers = "clr-namespace:WPF_Student_Management.Helpers" 
             Width="550">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <Border Background="White"
            CornerRadius="16"
            Padding="30">
        <StackPanel>
            <TextBlock Text="LẬP PHIẾU YÊU CẦU THAY ĐỔI"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1A237E"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25" />

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="0,0,15,0">
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Margin="5,0,0,5"
                               Foreground="#3e4c82"
                               Text="Mã học sinh" />
                    <TextBox Text="{Binding StudentId}"
                             IsReadOnly="True"
                             Background="#F0F0F0"
                             Style="{StaticResource RoundedTextBoxStyle}"
                             materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                             BorderThickness="0" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Margin="5,0,0,5"
                               Foreground="#3e4c82"
                               Text="Họ và tên" />
                    <TextBox Text="{Binding StudentName}"
                             IsReadOnly="True"
                             Background="#F0F0F0"
                             Style="{StaticResource RoundedTextBoxStyle}"
                             materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                             BorderThickness="0" />
                </StackPanel>
            </Grid>

            <TextBlock FontSize="14"
                       FontWeight="SemiBold"
                       Margin="5,0,0,5">
                <Run Text="Loại yêu cầu"
                     Foreground="#3e4c82" />
                <Run Text=" *"
                     Foreground="#FF4757" />
            </TextBlock>
            <ComboBox ItemsSource="{Binding RequestTypes}"
                      SelectedItem="{Binding SelectedRequestType, UpdateSourceTrigger=PropertyChanged}"
                      Height="40"
                      VerticalContentAlignment="Center"
                      Margin="0,0,0,15"
                      FontSize="15" />

            <StackPanel Visibility="{Binding IsTransferClassVisible, Converter={StaticResource BoolToVisConverter}}">
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Margin="5,0,0,5">
                    <Run Text="Lớp chuyển đến"
                         Foreground="#3e4c82" />
                    <Run Text=" *"
                         Foreground="#FF4757" />
                </TextBlock>
                <ComboBox ItemsSource="{Binding AvailableClasses}"
                          SelectedItem="{Binding SelectedTargetClass}"
                          DisplayMemberPath="Name"
                          Height="40"
                          VerticalContentAlignment="Center"
                          Margin="0,0,0,15"
                          FontSize="15" />
            </StackPanel>

            <TextBlock FontSize="14"
                       FontWeight="SemiBold"
                       Margin="5,0,0,5">
                <Run Text="Lý do yêu cầu"
                     Foreground="#3e4c82" />
                <Run Text=" *"
                     Foreground="#FF4757" />
            </TextBlock>
            <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource RoundedTextBoxStyle}"
                     helpers:TextBoxHelper.IsLettersOnly="True"
                     Height="100"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalContentAlignment="Top"
                     Padding="10,10" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Command="{Binding CancelCommand}"
                        Content="HỦY BỎ"
                        Width="100"
                        Height="40"
                        Margin="0,0,15,0"
                        Style="{StaticResource OutlineRoundedButton}" />
                <Button Command="{Binding SubmitCommand}"
                        Content="XÁC NHẬN"
                        Width="140"
                        Height="40"
                        Style="{StaticResource PrimaryRoundedButton}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>