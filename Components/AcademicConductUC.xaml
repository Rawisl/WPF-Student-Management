<UserControl x:Class="WPF_Student_Management.Components.AcademicConductUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:WPF_Student_Management.Components"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,20"
              VerticalAlignment="Bottom">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Tìm kiếm học sinh:"
                               Foreground="#878A99"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Margin="5,0,0,5" />
                    <Border CornerRadius="21"
                            BorderBrush="#D1D5DB"
                            BorderThickness="1"
                            Background="White"
                            Height="44"
                            Width="350">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Background="#2962FF"
                                    CornerRadius="21"
                                    Width="40"
                                    Height="40"
                                    Margin="1">
                                <materialDesign:PackIcon Kind="Magnify"
                                                         Foreground="White"
                                                         Width="25"
                                                         Height="25"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Border>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                     VerticalAlignment="Center"
                                     FontSize="15"
                                     Margin="10,0,15,0" />
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Vertical"
                            Margin="20,0,0,0">
                    <TextBlock Text="Giới tính:"
                               Foreground="#878A99"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Margin="5,0,0,5" />
                    <ComboBox ItemsSource="{Binding GenderList}"
                              SelectedItem="{Binding SelectedGender}"
                              Height="42"
                              Width="120"
                              FontSize="15"
                              VerticalContentAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Visibility="{Binding IsClassLocked, Converter={StaticResource BoolToVisConverter}}">
                <materialDesign:PackIcon Kind="Lock"
                                         Foreground="#D32F2F"
                                         Width="24"
                                         Height="24"
                                         Margin="0,0,5,0"
                                         VerticalAlignment="Center" />
                <TextBlock Text="HỌC KỲ ĐÃ ĐƯỢC TỔNG KẾT"
                           Foreground="#D32F2F"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
            </StackPanel>

        </Grid>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                ClipToBounds="True"
                Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Color="#DDDDDD"
                                  Opacity="0.5" />
            </Border.Effect>
            <DataGrid ItemsSource="{Binding DisplayStudents}"
                      SelectedItem="{Binding SelectedStudent}"
                      Cursor="Hand"
                      Style="{StaticResource GlobalDataGridStyle}"
                      CellStyle="{StaticResource GlobalDataGridCellStyle}"
                      FontSize="15">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="STT"
                                        Binding="{Binding STT}"
                                        IsReadOnly="True"
                                        HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                        ElementStyle="{StaticResource GlobalCenterElementStyle}">
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Mã HS"
                                        Binding="{Binding StudentId}"
                                        Width="100"
                                        IsReadOnly="True"
                                        HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                        ElementStyle="{StaticResource GlobalCenterElementStyle}" />
                    <DataGridTextColumn Header="Họ và Tên"
                                        Binding="{Binding FullName}"
                                        Width="*"
                                        IsReadOnly="True"
                                        HeaderStyle="{StaticResource GlobalLeftHeaderStyle}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"
                                   BasedOn="{StaticResource GlobalLeftElementStyle}">
                                <Setter Property="FontWeight"
                                        Value="SemiBold" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Giới Tính"
                                        Binding="{Binding Gender}"
                                        Width="100"
                                        IsReadOnly="True"
                                        HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                        ElementStyle="{StaticResource GlobalCenterElementStyle}" />
                    <DataGridTextColumn Header="Lớp"
                                        Binding="{Binding ClassName}"
                                        Width="100"
                                        IsReadOnly="True"
                                        HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                        ElementStyle="{StaticResource GlobalCenterElementStyle}" />
                    <DataGridTextColumn Header="Điểm TB"
                                        Binding="{Binding AverageScore}"
                                        Width="150"
                                        FontWeight="Bold"
                                        IsReadOnly="True"
                                        HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                        ElementStyle="{StaticResource GlobalCenterElementStyle}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>