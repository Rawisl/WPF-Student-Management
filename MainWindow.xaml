<Window x:Class="WPF_Student_Management.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
        xmlns:views="clr-namespace:WPF_Student_Management.Views"
        xmlns:local="clr-namespace:WPF_Student_Management" 
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:ClassRosterViewModel}">
            <views:ClassRosterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SubjectGradebookViewModel}">
            <views:SubjectGradebookView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:HomeroomDashboardViewModel}">
            <views:HomeroomDashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:GlobalStudentManagementViewModel}">
            <views:GlobalStudentManagementView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:RegulationSettingsViewModel}">
            <views:RegulationSettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <materialDesign:DialogHost 
        Identifier="RootDialog" 
        CloseOnClickAway="True">
        <Grid x:Name="MainGrid">
            <!-- Grid chia giữa Sidebar và UserContent -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="Sidebar" Width="250"/>
                <ColumnDefinition x:Name="Main_Content" Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- StackPanel tránh các button đè nhau -->
            <StackPanel x:Name="StPn_Button" HorizontalAlignment="Center" Height="304" VerticalAlignment="Center" Width="230">
                <Button Content="Xếp lớp" 
            Command="{Binding NavigateCommand}" 
            CommandParameter="{Binding ClassRosterVM}"/>

                <Button Content="Sổ điểm môn học" 
            Command="{Binding NavigateCommand}" 
            CommandParameter="{Binding SubjectGradebookVM}"/>

                <Button Content="Lớp chủ nhiệm" 
            Command="{Binding NavigateCommand}" 
            CommandParameter="{Binding HomeroomDashboardVM}"/>

                <Button Content="Danh sách toàn trường" 
            Command="{Binding NavigateCommand}" 
            CommandParameter="{Binding GlobalStudentManagementVM}"/>

                <Button Content="Thay đổi quy định" 
            Command="{Binding NavigateCommand}" 
            CommandParameter="{Binding RegulationSettingsVM}"/>

                <Button Content="Cài đặt" 
            Command="{Binding NavigateCommand}" 
            CommandParameter="{Binding SettingsVM}"/>
            </StackPanel>

            <ContentControl 
            x:Name="MainContent" 
            Grid.Column="1" 
            Content="{Binding CurrentView}" 
            HorizontalAlignment="Stretch" 
            VerticalAlignment="Stretch"
            Margin="20"/>
        </Grid>
    </materialDesign:DialogHost>
</Window>