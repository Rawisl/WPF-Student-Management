<UserControl x:Class="WPF_Student_Management.Views.EnrollmentChangeExecutionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1000">

    <materialDesign:DialogHost Identifier="ExecutionDialogHost"
                               DialogBackground="Transparent"
                               DialogMargin="0">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Margin="0,0,0,20">
                <TextBlock Text="Xử lý đơn chuyển lớp / thôi học"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1A237E" />
                <TextBlock Text="Danh sách các đơn yêu cầu đang chờ Giáo vụ xét duyệt và thực thi."
                           FontSize="15"
                           Foreground="#878A99"
                           Margin="0,5,0,0" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="1"
                                      Color="#DDDDDD"
                                      Opacity="0.5" />
                </Border.Effect>

                <DataGrid ItemsSource="{Binding PendingRequests}"
                          Style="{StaticResource GlobalDataGridStyle}"
                          CellStyle="{StaticResource GlobalDataGridCellStyle}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeColumns="False"
                          HeadersVisibility="Column"
                          Background="Transparent"
                          RowHeight="50"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT"
                                            Binding="{Binding STT}"
                                            IsReadOnly="True"
                                            Width="60"
                                            CanUserSort="False"
                                            HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                            ElementStyle="{StaticResource GlobalCenterElementStyle}" />

                        <DataGridTextColumn Header="Học sinh"
                                            Binding="{Binding FullName}"
                                            IsReadOnly="True"
                                            Width="*"
                                            HeaderStyle="{StaticResource GlobalLeftHeaderStyle}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"
                                       BasedOn="{StaticResource GlobalLeftElementStyle}">
                                    <Setter Property="FontWeight"
                                            Value="SemiBold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Lớp hiện tại"
                                            Binding="{Binding CurrentClassName}"
                                            IsReadOnly="True"
                                            Width="100"
                                            HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                            ElementStyle="{StaticResource GlobalCenterElementStyle}" />

                        <DataGridTemplateColumn Header="Loại yêu cầu"
                                                Width="120"
                                                HeaderStyle="{StaticResource GlobalCenterHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RequestTypeDisplay}"
                                               Foreground="{Binding RequestTypeTextColor}"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Lớp đích"
                                            Binding="{Binding TargetClassName}"
                                            IsReadOnly="True"
                                            Width="100"
                                            HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                            ElementStyle="{StaticResource GlobalCenterElementStyle}" />

                        <DataGridTextColumn Header="Lý do"
                                            Binding="{Binding Reason}"
                                            IsReadOnly="True"
                                            Width="250"
                                            HeaderStyle="{StaticResource GlobalLeftHeaderStyle}"
                                            ElementStyle="{StaticResource GlobalLeftElementStyle}" />

                        <DataGridTemplateColumn Header="Thao tác"
                                                Width="110"
                                                CanUserSort="False"
                                                HeaderStyle="{StaticResource GlobalCenterHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility"
                                                        Value="Hidden" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                                                                 Value="True">
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <Button Command="{Binding DataContext.ExecuteRequestCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Duyệt và thực thi đơn này"
                                                Foreground="#00B894"
                                                Background="Transparent"
                                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                BorderThickness="0"
                                                Width="35"
                                                Height="35"
                                                Margin="0,0,10,0"
                                                Padding="0"
                                                Cursor="Hand">
                                            <materialDesign:PackIcon Kind="CheckBold"
                                                                     Width="22"
                                                                     Height="22"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center" />
                                        </Button>

                                        <Button Command="{Binding DataContext.OpenRejectDialogCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Trả đơn về cho GVCN"
                                                Foreground="#FF4757"
                                                Background="Transparent"
                                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                BorderThickness="0"
                                                Width="35"
                                                Height="35"
                                                Padding="0"
                                                Cursor="Hand">
                                            <materialDesign:PackIcon Kind="CloseThick"
                                                                     Width="22"
                                                                     Height="22"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
     
    </materialDesign:DialogHost>

</UserControl>