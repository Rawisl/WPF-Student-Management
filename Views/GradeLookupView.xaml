<UserControl x:Class="WPF_Student_Management.Views.GradeLookupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:components="clr-namespace:WPF_Student_Management.Components"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,20">
            <TextBlock Text="Tra cứu điểm cá nhân"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1A237E" />
            <TextBlock Text="Xem chi tiết kết quả học tập theo từng học kỳ"
                       FontSize="15"
                       Foreground="#878A99"
                       Margin="0,5,0,0" />
        </StackPanel>

        <!--asdasdsadasd-->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Color="#DDDDDD"
                                  Opacity="0.5" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                    <StackPanel Grid.Column="0"
                                Margin="0,0,20,0">
                        <TextBlock Text="Năm học:"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,5"
                                   Foreground="Black" />

                        <ComboBox ItemsSource="{Binding AvailableAcademicYears}"
                                  SelectedItem="{Binding SelectedAcademicYear}"
                                  Width="130"
                                  Height="40"
                                  Margin="0,0,25,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="0,0,20,0">
                        <TextBlock Text="Học kỳ:"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,5"
                                   Foreground="Black" />
                        <ComboBox ItemsSource="{Binding AvailableSemesters}"
                                  SelectedItem="{Binding SelectedSemester}"
                                  Width="130"
                                  Height="40"
                                  Margin="0,0,25,0" />
                    </StackPanel>
                </StackPanel>

                <Button Command="{Binding ViewGradeCommand}"
                        Content="XEM ĐIỂM"
                        Style="{StaticResource PrimaryRoundedButton}"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Right" />
            </Grid>
        </Border>
        <!--asdasdsadasd-->


        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Color="#DDDDDD"
                                  Opacity="0.5" />
            </Border.Effect>
            <Grid>
                <StackPanel Visibility="{Binding IsMessageVisible, Converter={StaticResource BoolToVis}}" />
                <components:StudentGradeDetailUC DataContext="{Binding GradeDetailVM}"
                                                 Visibility="{Binding IsTableVisible, Converter={StaticResource BoolToVis}}"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Stretch" />
            </Grid>
        </Border>

    </Grid>
</UserControl>