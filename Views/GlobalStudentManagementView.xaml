<UserControl x:Class="WPF_Student_Management.Views.GlobalStudentManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Views"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:components="clr-namespace:WPF_Student_Management.Components"
             xmlns:helpers="clr-namespace:WPF_Student_Management.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center">
                <TextBlock Text="Danh sách học sinh"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1A237E" />

                <TextBlock Text="Quản lý thông tin của học sinh toàn trường"
                           FontSize="14"
                           Foreground="#878A99"
                           Margin="0,5,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Visibility="{Binding ActionVisibility}">
                <Button Command="{Binding AddStudentCommand}"
                        Height="42"
                        Padding="15,0,15,0"
                        Style="{StaticResource PrimaryRoundedButton}">

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="PlusBoxOutline"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Tiếp nhận học sinh"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,20"
                    VerticalAlignment="Bottom">

            <StackPanel Orientation="Vertical">
                <TextBlock Text="Tìm kiếm học sinh:"
                           Foreground="#878A99"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="5,0,0,5" />

                <Border CornerRadius="21"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        Background="White"
                        Height="44"
                        Width="350">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#2962FF"
                                CornerRadius="21"
                                Width="40"
                                Height="40"
                                Margin="1">
                            <materialDesign:PackIcon Kind="Magnify"
                                                     Foreground="White"
                                                     Width="25"
                                                     Height="25"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>

                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 helpers:TextBoxHelper.IsLettersOnly="True"
                                 BorderThickness="0"
                                 materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                 VerticalAlignment="Center"
                                 FontSize="15"
                                 Margin="10,0,15,0" />
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Orientation="Vertical"
                        Margin="20,0,0,0">
                <TextBlock Text="Giới tính:"
                           Foreground="#878A99"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="5,0,0,5" />

                <ComboBox ItemsSource="{Binding GenderList}"
                          SelectedItem="{Binding SelectedGender}"
                          Height="42"
                          Width="120"
                          FontSize="15"
                          VerticalContentAlignment="Center" />
            </StackPanel>

        </StackPanel>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Color="#DDDDDD"
                                  Opacity="0.5" />
            </Border.Effect>

            <components:StudentProfileUC ItemsSource="{Binding AllStudent}"
                                         EditCommand="{Binding EditStudentCommand}"
                                         DeleteCommand="{Binding DeleteStudentCommand}" />
        </Border>
    </Grid>
</UserControl>