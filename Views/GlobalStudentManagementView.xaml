<UserControl x:Class="WPF_Student_Management.Views.GlobalStudentManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Views"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:components="clr-namespace:WPF_Student_Management.Components"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <UserControl.DataContext>
        <viewmodels:GlobalStudentManagementViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0"
                             Margin="0,0,0,20"
                             Padding="15,10"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"
                             BorderBrush="#E0E0E0"
                             BorderThickness="1"
                             UniformCornerRadius="15">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Content="+ Tiếp nhận học sinh"
                        Command="{Binding AddStudentCommand}"
                        FontSize="15"
                        Margin="40,0,0,0"
                        Height="40"
                        Cursor="Hand"
                        Style="{StaticResource PrimaryRoundedButton}">
                </Button>
            </StackPanel>
        </materialDesign:Card>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Color="#DDDDDD"
                                  Opacity="0.5" />
            </Border.Effect>

            <components:StudentDataGridUC ItemsSource="{Binding AllStudent}"
                                          EditCommand="{Binding EditStudentCommand}"
                                          DeleteCommand="{Binding DeleteStudentCommand}" />
        </Border>
    </Grid>
</UserControl>