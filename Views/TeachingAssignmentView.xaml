<UserControl x:Class="WPF_Student_Management.Views.TeachingAssignmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Views"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000">

    <UserControl.DataContext>
        <viewmodels:TeachingAssignmentViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Phân công giảng dạy" FontSize="28" FontWeight="Bold" Foreground="#1A237E" />
                <TextBlock Text="Quản lý và gán giáo viên phụ trách cho từng môn học của các lớp" FontSize="14" Foreground="#878A99" Margin="0,5,0,0" />
            </StackPanel>

            <Border Grid.Column="1" Background="#E8EAF6" CornerRadius="12" Padding="15,10" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Right">
                    <TextBlock Text="HỌC KỲ HIỆN HÀNH" FontSize="12" FontWeight="Bold" Foreground="#5C6BC0" HorizontalAlignment="Right"/>
                    <TextBlock Text="HK1 - Năm học 2025-2026" FontSize="18" FontWeight="ExtraBlack" Foreground="#1A237E" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,20" VerticalAlignment="Bottom">

            <StackPanel Orientation="Vertical" Margin="0,0,20,0" HorizontalAlignment="Left">
                <TextBlock Text="Chọn lớp học:" Foreground="#878A99" FontWeight="SemiBold" FontSize="13" Margin="5,0,0,5" />

                <ComboBox ItemsSource="{Binding ClassList}"
                          SelectedItem="{Binding SelectedClass}"
                          DisplayMemberPath="ClassName"
                          Height="42" Width="140" FontSize="15" 
                          VerticalContentAlignment="Center"/>
            </StackPanel>

            <Button Command="{Binding SaveCommand}"
                    Height="42" Padding="15,0,15,0"
                    Style="{StaticResource PrimaryRoundedButton}"
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ContentSaveOutline" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="Lưu phân công" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Color="#DDDDDD"
                                  Opacity="0.5" />
            </Border.Effect>

            <!-- 1. Bơm Style Global vào đây để khử viền xấu và chuẩn hóa UI -->
            <DataGrid ItemsSource="{Binding AssignmentList}"
                      Style="{StaticResource GlobalDataGridStyle}"
                      CellStyle="{StaticResource GlobalDataGridCellStyle}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      FontSize="15">

                <DataGrid.Columns>
                    <!-- 2. Cột Môn Học: Áp dụng HeaderStyle và ElementStyle giống bản chuẩn -->
                    <DataGridTextColumn Header="Môn Học"
                                        Binding="{Binding SubjectName}"
                                        IsReadOnly="True"
                                        Width="2*"
                                        HeaderStyle="{StaticResource GlobalLeftHeaderStyle}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"
                                   BasedOn="{StaticResource GlobalLeftElementStyle}">
                                <!-- Làm đậm tên môn học lên chút cho đẹp -->
                                <Setter Property="FontWeight"
                                        Value="SemiBold" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 3. Cột Giáo Viên: Bóp lại ComboBox cho gọn gàng -->
                    <DataGridTemplateColumn Header="Giáo Viên Phụ Trách"
                                            Width="3*"
                                            HeaderStyle="{StaticResource GlobalLeftHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <!-- Thêm Margin, căn giữa dọc và áp dụng Style của MaterialDesign -->
                                <ComboBox ItemsSource="{Binding AvailableTeachers}"
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="StaffId"
                                          SelectedValue="{Binding SelectedTeacherId, UpdateSourceTrigger=PropertyChanged}"
                                          materialDesign:HintAssist.Hint="-- Chọn giáo viên --"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          Margin="10,0,30,0"
                                          Padding="5,8"
                                          FontSize="15"
                                          Cursor="Hand" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>