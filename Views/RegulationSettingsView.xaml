<UserControl x:Class="WPF_Student_Management.Views.RegulationSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             xmlns:helpers="clr-namespace:WPF_Student_Management.Helpers"
             xmlns:components="clr-namespace:WPF_Student_Management.Components"
             mc:Ignorable="d"
             d:DesignHeight="2000"
             d:DesignWidth="900">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center">
                <TextBlock Text="Thiết lập quy định"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1A237E" />

                <TextBlock Text="Cài đặt quy định chung trên phạm vi toàn trường"
                           FontSize="14"
                           Foreground="#878A99"
                           Margin="0,5,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Command="{Binding SaveSettingsCommand}"
                        Height="42"
                        Padding="15,0,15,0"
                        Style="{StaticResource PrimaryRoundedButton}">

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="CheckAll"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Lưu thay đổi"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Hidden">
            <StackPanel Margin="0,0,0,0"
                        HorizontalAlignment="Stretch">

                <components:AgeRegulationUC />

                <components:ClassSizeRegulationUC />

                <components:PassingGradeRegulationUC />

                <components:GradeWeightRegulationUC />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

