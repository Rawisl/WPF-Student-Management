<UserControl x:Class="WPF_Student_Management.Views.RegulationSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             xmlns:helpers="clr-namespace:WPF_Student_Management.Helpers"
             xmlns:components="clr-namespace:WPF_Student_Management.Components"
             mc:Ignorable="d"
             d:DesignHeight="2000"
             d:DesignWidth="900">

    <UserControl.DataContext>
        <viewmodels:RegulationSettingsViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,20"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Top">
            <TextBlock HorizontalAlignment="Left"
                       TextWrapping="Wrap"
                       Text="Thay đổi quy định"
                       VerticalAlignment="Center"
                       FontSize="36"
                       TextAlignment="Center"
                       FontWeight="Bold" />

            <Button x:Name="SaveBtn"
                    Content="Lưu thay đổi"
                    Command="{Binding SaveSettingsCommand}"
                    HorizontalAlignment="Right"
                    Height="50"
                    VerticalAlignment="Center"
                    Width="174"
                    FontSize="20"
                    Foreground="White"
                    Background="#FF0006FF"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius"
                                Value="10" />
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="IsEnabled"
                                Value="{Binding HasUnsavedChanges}" />
                        <Style.Triggers>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Background"
                                        Value="LightGray" />
                                <Setter Property="Foreground"
                                        Value="DarkGray" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <ScrollViewer HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Hidden">
            <StackPanel Margin="0,0,0,0"
                        HorizontalAlignment="Stretch">

                <components:AgeRegulationUC />

                <components:ClassSizeRegulationUC />

                <components:PassingGradeRegulationUC />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

