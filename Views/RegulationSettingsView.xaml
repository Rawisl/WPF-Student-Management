<UserControl x:Class="WPF_Student_Management.Views.RegulationSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_Student_Management.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             xmlns:helpers="clr-namespace:WPF_Student_Management.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="2000" d:DesignWidth="900">

    <UserControl.DataContext>
        <viewmodels:RegulationSettingsViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Stretch" VerticalAlignment="Top">
            <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="Thay đổi quy định" VerticalAlignment="Center" FontSize="36" TextAlignment="Center" FontWeight="Bold"/>

            <Button x:Name="SaveBtn"
                Content="Lưu thay đổi"
                Command="{Binding SaveSettingsCommand}"
                HorizontalAlignment="Right"
                Height="50" 
                VerticalAlignment="Center"
                Width="174"
                FontSize="20" 
                Foreground="White"
                Background="#FF0006FF"
                Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="IsEnabled" Value="{Binding HasUnsavedChanges}"/>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="LightGray"/>
                                <Setter Property="Foreground" Value="DarkGray"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <ScrollViewer HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Row="1" VerticalScrollBarVisibility="Hidden">
            <StackPanel Margin="0,0,0,0"
                    HorizontalAlignment="Stretch">

                <materialDesign:Card 
                Margin="0,0,0,20" 
                Padding="20" 
                UniformCornerRadius="20" 
                BorderBrush="Black" 
                BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Quy định về Tuổi" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" Foreground="#FF1A237E"/>
                        <Separator Margin="0,0,0,15" Background="#F0F0F0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Label Content="Tuổi tối thiểu:" Foreground="Black" Margin="0,0,0,5" FontSize="18" FontWeight="Bold"/>
                                <Border Background="#F3F5F9" CornerRadius="10" Height="45" BorderBrush="#D2D6DC" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtTuoiMin"
                                             Text="{Binding MinAge, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                             BorderThickness="0" 
                                             Background="Transparent" 
                                             VerticalContentAlignment="Center" 
                                             Padding="15,0" FontSize="16" 
                                             helpers:TextBoxHelper.IsNumericOnly="True" 
                                             Grid.Column="0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <Button Command="{Binding IncreaseMinAgeCommand}" Content="▲" Height="18" Padding="0" Background="Transparent" BorderThickness="0" Foreground="Gray"/>
                                            <Button Command="{Binding DecreaseMinAgeCommand}" Content="▼" Height="18" Padding="0" Background="Transparent" BorderThickness="0" Foreground="Gray"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Label Content="Tuổi tối đa:" Foreground="Black" Margin="0,0,0,5" FontSize="18" FontWeight="Bold"/>
                                <Border Background="#F3F5F9" CornerRadius="10" Height="45" BorderBrush="#D2D6DC" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtTuoiMax"
                                             Text="{Binding MaxAge, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             VerticalContentAlignment="Center"
                                             Padding="15,0" FontSize="16"
                                             helpers:TextBoxHelper.IsNumericOnly="True"
                                             Grid.Column="0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <Button Command="{Binding IncreaseMaxAgeCommand}" Content="▲" Height="18" Padding="0" Background="Transparent" BorderThickness="0" Foreground="Gray"/>
                                            <Button Command="{Binding DecreaseMaxAgeCommand}" Content="▼" Height="18" Padding="0" Background="Transparent" BorderThickness="0" Foreground="Gray"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="0,0,0,20" Padding="20" UniformCornerRadius="20" BorderBrush="Black" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Quy định về Lớp học" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" Foreground="#FF1A237E"/>
                        <Separator Margin="0,0,0,15" Background="#F0F0F0"/>

                        <Label Content="Sĩ số tối đa:" Foreground="Black" Margin="0,0,0,5" FontSize="18" FontWeight="Bold"/>
                        <Border Background="#F3F5F9" CornerRadius="10" Height="45" Width="300" HorizontalAlignment="Left" Margin="0,0,0,20" BorderBrush="#D2D6DC" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtSiSoMax"
                                     Text="{Binding MaxClassSize, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Padding="15,0" FontSize="16"
                                     helpers:TextBoxHelper.IsNumericOnly="True" 
                                     Grid.Column="0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,5,0">
                                    <Button Command="{Binding IncreaseClassSizeCommand}" Content="▲" Height="18" Padding="0" Background="Transparent" BorderThickness="0" Foreground="Gray"/>
                                    <Button Command="{Binding ReduceClassSizeCommand}" Content="▼" Height="18" Padding="0" Background="Transparent" BorderThickness="0" Foreground="Gray"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Cấu hình danh sách lớp:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="16"/>
                            <Button Command="{Binding AddClassCommand}" Content="+ Thêm lớp" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="#FF270EDC" FontWeight="Bold" Cursor="Hand"/>
                        </Grid>

                        <DataGrid x:Name="dgLopHoc" ItemsSource="{Binding ClassList}" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" BorderThickness="1" BorderBrush="#F0F0F0" RowHeight="40" ColumnHeaderHeight="40">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="STT" Binding="{Binding OrdinalNumber}" Width="60" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="Khối" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#F3F5F9" CornerRadius="5" Margin="2">
                                                <TextBox Text="{Binding Grade, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Padding="5,2"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Tên lớp" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#F3F5F9" CornerRadius="5" Margin="2">
                                                <TextBox Text="{Binding ClassName, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Padding="5,2"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Xóa" Binding="{Binding DeleteIcon}" Width="60" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="Red"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="0,0,0,20" Padding="20" UniformCornerRadius="20" BorderBrush="Black" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Quy định về Môn học" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" Foreground="#FF1A237E"/>
                        <Separator Margin="0,0,0,15" Background="#F0F0F0"/>

                        <Label Content="Điểm đạt (Pass score):" Foreground="Black" Margin="0,0,0,5" FontSize="18" FontWeight="Bold"/>
                        <Border Background="#F3F5F9" CornerRadius="10" Height="45" Width="300" HorizontalAlignment="Left" Margin="0,0,0,20" BorderBrush="#D2D6DC" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtPassScore"
                                    Text="{Binding PassingGrade, UpdateSourceTrigger=LostFocus, Delay=500, TargetNullValue=''}"
                                    BorderThickness="0" 
                                    Background="Transparent" 
                                    VerticalContentAlignment="Center" 
                                    Padding="15,0" 
                                    FontSize="16" 
                                    helpers:TextBoxHelper.IsDecimalOnly="True" 
                                    Grid.Column="0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,5,0">
                                    <Button Command="{Binding IncreasePassingGradeCommand}" Content="▲" Height="18" Padding="0" Background="Transparent" BorderThickness="0" Foreground="Gray"/>
                                    <Button Command="{Binding DecreasePassingGradeCommand}" Content="▼" Height="18" Padding="0" Background="Transparent" BorderThickness="0" Foreground="Gray"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Cấu hình danh sách môn học" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="16"/>
                            <Button Command="{Binding AddSubjectCommand}" Content="+ Thêm môn" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="#FF270EDC" FontWeight="Bold" Cursor="Hand"/>
                        </Grid>

                        <DataGrid x:Name="dgMonHoc" ItemsSource="{Binding SubjectList}" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" BorderThickness="1" BorderBrush="#F0F0F0" RowHeight="40" ColumnHeaderHeight="40">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="STT" Binding="{Binding OrdinalNumber}" Width="60" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="Tên môn học" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#F3F5F9" CornerRadius="5" Margin="2">
                                                <TextBox Text="{Binding SubjectName, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Padding="5,2"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Xóa" Binding="{Binding DeleteIcon}" Width="60" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="Red"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

