<UserControl x:Class="WPF_Student_Management.Views.ClassRosterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_Student_Management.Views"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             xmlns:components="clr-namespace:WPF_Student_Management.Components"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,20">

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Xếp lớp"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1A237E" />

                <TextBlock Text="Phân bổ học sinh vào các lớp học"
                           FontSize="14"
                           Foreground="#878A99"
                           Margin="0,5,0,0" />
            </StackPanel>
        </Grid>

        <materialDesign:Card Grid.Row="1"
                             Margin="0,0,0,20"
                             Padding="15,10"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"
                             BorderBrush="#E0E0E0"
                             BorderThickness="1"
                             UniformCornerRadius="15">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Label Content="Khối:"
                       FontSize="18"
                       Foreground="Gray"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold" />
                <ComboBox x:Name="PickGradeCB"
                          ItemsSource="{Binding AvailableGrades}"
                          SelectedItem="{Binding SelectedGrade, UpdateSourceTrigger=PropertyChanged}"
                          Width="100"
                          Height="35"
                          Margin="5,0,20,0"
                          VerticalAlignment="Center" />

                <Label Content="Lớp:"
                       FontSize="18"
                       Foreground="Gray"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold" />
                <ComboBox x:Name="PickClassCB"
                          ItemsSource="{Binding AvailableClasses}"
                          DisplayMemberPath="ClassName"
                          SelectedValuePath="ClassId"
                          SelectedValue="{Binding SelectedClass, UpdateSourceTrigger=PropertyChanged}"
                          Width="120"
                          Height="35"
                          Margin="5,0,20,0"
                          VerticalAlignment="Center" />

                <TextBlock Text="{Binding ClassSizeText}"
                           Foreground="#2C3E50"
                           FontWeight="Bold"
                           FontSize="18"
                           VerticalAlignment="Center"
                           Margin="20,0,30,0" />

                <Button Content="+ Thêm học sinh"
                        Command="{Binding OpenAddStudentDialogCommand}"
                        Style="{StaticResource PrimaryRoundedButton}">
                </Button>
            </StackPanel>
        </materialDesign:Card>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Color="#DDDDDD"
                                  Opacity="0.5" />
            </Border.Effect>

            <components:StudentProfileUC ItemsSource="{Binding CurrentClassStudents}"
                                         ShowActionColumn="False" />
        </Border>
    </Grid>

</UserControl>