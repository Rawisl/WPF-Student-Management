<Window x:Class="WPF_Student_Management.Views.ForceChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_Student_Management.Views"
        xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:components="clr-namespace:WPF_Student_Management.Components"
        mc:Ignorable="d"
        Title="Đổi mật khẩu"
        Height="550"
        Width="420"
        WindowStartupLocation="CenterScreen"
        Icon="/Images/student-management-logo.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>
    
    <Border Background="#F5F6FA"
            CornerRadius="10"
            BorderBrush="#D1D5DB"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <components:CustomTopBarUC Grid.Row="0"
                                       TitleText="Đăng nhập"
                                       ShowMaximizeButton="Hidden" />
            
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="12"
                    Margin="30"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="1"
                                      Color="#DDDDDD"
                                      Opacity="0.5" />
                </Border.Effect>
                <local:SettingsView />
            </Border>

        </Grid>
    </Border>
</Window>