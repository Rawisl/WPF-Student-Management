<Window x:Class="WPF_Student_Management.Views.ForceChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_Student_Management.Views"
        xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:components="clr-namespace:WPF_Student_Management.Components"
        mc:Ignorable="d"
        Title="Bảo mật tài khoản"
        Height="550" Width="450"
        WindowStartupLocation="CenterScreen"
        Icon="/Images/student-management-logo.ico"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Name="ForceChangePwdWindow">

    <Window.DataContext>
        <viewmodels:ForceChangePasswordViewModel />
    </Window.DataContext>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Background="#F5F6FA" CornerRadius="10" BorderBrush="#D1D5DB" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <components:CustomTopBarUC Grid.Row="0" TitleText="Bảo mật tài khoản" ShowMaximizeButton="Hidden" />

            <Border Grid.Row="1" Background="White" CornerRadius="12" Margin="30" Padding="30,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#DDDDDD" Opacity="0.5" />
                </Border.Effect>

                <StackPanel VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ShieldLockOutline" Width="55" Height="55" Foreground="#2962FF" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <TextBlock Text="ĐỔI MẬT KHẨU BẮT BUỘC" FontSize="20" FontWeight="Bold" Foreground="#1A237E" HorizontalAlignment="Center"/>

                    <TextBlock Text="Đây là lần đăng nhập đầu tiên. Vui lòng đổi mật khẩu để đảm bảo an toàn cho tài khoản." 
                               TextWrapping="Wrap" TextAlignment="Center" FontSize="14" Foreground="#878A99" Margin="0,10,0,30"/>

                    <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Mật khẩu mới (ít nhất 6 ký tự)"
                             FontFamily="Password"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0,0,0,20" FontSize="15" />

                    <TextBox Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Xác nhận mật khẩu mới"
                             FontFamily="Password"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0,0,0,35" FontSize="15" />

                    <Button Command="{Binding ChangePasswordCommand}"
                            CommandParameter="{Binding ElementName=ForceChangePwdWindow}"
                            Content="XÁC NHẬN" Height="45" FontSize="16" FontWeight="Bold"
                            Style="{StaticResource PrimaryRoundedButton}" Cursor="Hand"
                            IsDefault="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>