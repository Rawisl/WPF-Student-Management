<UserControl x:Class="WPF_Student_Management.Views.HomeroomDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             xmlns:components="clr-namespace:WPF_Student_Management.Components"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="#F8F9FA">

    <UserControl.DataContext>
        <viewmodels:HomeroomDashboardViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Bảng điều khiển Lớp chủ nhiệm" FontSize="28" FontWeight="Bold" Foreground="#1A237E" />
            <TextBlock Text="{Binding ClassTitle}" FontSize="15" Foreground="#878A99" Margin="0,5,0,0" FontWeight="SemiBold" />
        </StackPanel>

        <TabControl Grid.Row="1" 
                    Style="{StaticResource MaterialDesignTabControl}" 
                    Background="Transparent"
                    BorderThickness="0"
                    d:SelectedIndex="0">

            <TabControl.Resources>
                <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="#673AB7"/>
            </TabControl.Resources>

            <TabItem>
                <TabItem.Header>
                    <Grid Width="380">
                        <TextBlock Text="Điểm quá trình" 
                                   FontSize="17" 
                                   FontWeight="SemiBold" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>

                <materialDesign:Card Margin="0,15,0,0" 
                                     Padding="15" 
                                     UniformCornerRadius="12" 
                                     materialDesign:ElevationAssist.Elevation="Dp2"
                                     Background="White">
                    <components:AcademicConductUC DataContext="{Binding}" />
                </materialDesign:Card>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <Grid Width="380">
                        <TextBlock Text="Tổng kết học kỳ" 
                                   FontSize="17" 
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>

                <materialDesign:Card Margin="0,15,0,0" 
                                     Padding="15" 
                                     UniformCornerRadius="12" 
                                     materialDesign:ElevationAssist.Elevation="Dp2"
                                     Background="White">
                    <components:TermSummaryUC DataContext="{Binding}" />
                </materialDesign:Card>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>