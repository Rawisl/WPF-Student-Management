<UserControl x:Class="WPF_Student_Management.Views.HomeroomDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             Background="Transparent">

    <UserControl.DataContext>
        <viewmodels:HomeroomDashboardViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Điểm trung bình lớp chủ nhiệm"
                           FontSize="28" FontWeight="Bold" Foreground="#1A237E" />
                <TextBlock Text="{Binding ClassTitle}"
                           FontSize="15" Foreground="#878A99" Margin="0,5,0,0" FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Tìm kiếm theo tên học sinh..."
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Width="250" FontSize="15" Margin="0,0,20,0" VerticalAlignment="Bottom">
                </TextBox>

                <ComboBox ItemsSource="{Binding GenderList}"
                          SelectedItem="{Binding SelectedGender}"
                          materialDesign:HintAssist.Hint="Giới tính"
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                          Width="120" FontSize="15" Margin="0,0,0,0" VerticalAlignment="Bottom"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#DDDDDD" Opacity="0.5" />
            </Border.Effect>

            <DataGrid ItemsSource="{Binding DisplayStudents}" 
                      SelectedItem="{Binding SelectedStudent}"   
                      Cursor="Hand"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Background="Transparent"
                      BorderThickness="0"
                      RowHeight="55" FontSize="15">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="STT" Binding="{Binding STT}" CanUserSort="False" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Mã HS" Binding="{Binding StudentId}" Width="100"/>
                    <DataGridTextColumn Header="Họ và Tên" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Giới Tính" Binding="{Binding Gender}" Width="100"/>
                    <DataGridTextColumn Header="Lớp" Binding="{Binding ClassName}" Width="100"/>

                    <DataGridTextColumn Header="Điểm TB" Binding="{Binding AverageScore}" Width="150" FontWeight="Bold" Foreground="#E65100"/>
                </DataGrid.Columns>

            </DataGrid>
        </Border>
    </Grid>
</UserControl>