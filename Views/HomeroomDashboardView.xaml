<UserControl x:Class="WPF_Student_Management.Views.HomeroomDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             Background="Transparent">

    <UserControl.DataContext>
        <viewmodels:HomeroomDashboardViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,25">
            <TextBlock Text="Điểm trung bình lớp chủ nhiệm"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1A237E" />
            <TextBlock Text="{Binding ClassTitle}"
                       FontSize="15"
                       Foreground="#878A99"
                       Margin="0,5,0,0"
                       FontWeight="SemiBold" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,20"
                    VerticalAlignment="Bottom">

            <StackPanel Orientation="Vertical">
                <TextBlock Text="Tìm kiếm học sinh:"
                           Foreground="#878A99"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="5,0,0,5" />
                
                <Border CornerRadius="21"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        Background="White"
                        Height="44"
                        Width="350">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#2962FF"
                                CornerRadius="21"
                                Width="40"
                                Height="40"
                                Margin="1">
                            <materialDesign:PackIcon Kind="Magnify"
                                                     Foreground="White"
                                                     Width="25"
                                                     Height="25"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>

                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                 VerticalAlignment="Center"
                                 FontSize="15"
                                 Margin="10,0,15,0" />
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Orientation="Vertical"
                        Margin="20,0,0,0">
                <TextBlock Text="Giới tính:"
                           Foreground="#878A99"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="5,0,0,5" />

                <ComboBox ItemsSource="{Binding GenderList}"
                          SelectedItem="{Binding SelectedGender}"
                          Height="42"
                          Width="120"
                          FontSize="15"
                          VerticalContentAlignment="Center" />
            </StackPanel>

        </StackPanel>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Color="#DDDDDD"
                                  Opacity="0.5" />
            </Border.Effect>

            <Border CornerRadius="12"
                    ClipToBounds="True"
                    Padding="15">
                <DataGrid ItemsSource="{Binding DisplayStudents}"
                          SelectedItem="{Binding SelectedStudent}"
                          Cursor="Hand"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="Transparent"
                          BorderThickness="0"
                          RowHeight="55"
                          FontSize="15">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT"
                                            Binding="{Binding STT}"
                                            CanUserSort="False"
                                            Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment"
                                            Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Mã HS"
                                            Binding="{Binding StudentId}"
                                            Width="100" />
                        <DataGridTextColumn Header="Họ và Tên"
                                            Binding="{Binding FullName}"
                                            Width="*" />
                        <DataGridTextColumn Header="Giới Tính"
                                            Binding="{Binding Gender}"
                                            Width="100" />
                        <DataGridTextColumn Header="Lớp"
                                            Binding="{Binding ClassName}"
                                            Width="100" />
                        <DataGridTextColumn Header="Điểm TB"
                                            Binding="{Binding AverageScore}"
                                            Width="150"
                                            FontWeight="Bold"
                                            Foreground="#E65100" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Border>
    </Grid>
</UserControl>