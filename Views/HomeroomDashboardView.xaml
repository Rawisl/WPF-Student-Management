<UserControl x:Class="WPF_Student_Management.Views.HomeroomDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             xmlns:components="clr-namespace:WPF_Student_Management.Components"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1000">

    <UserControl.DataContext>
        <viewmodels:HomeroomDashboardViewModel />
    </UserControl.DataContext>
    <!--Phải định nghĩa cái style riêng ở đây vì t nghĩ chắc sẽ k reuse nhiều ở đâu-->
    <UserControl.Resources>
        <Style x:Key="SegmentedLeftTabStyle"
               TargetType="TabItem">
            <Setter Property="MinHeight"
                    Value="45" />
            <Setter Property="Margin"
                    Value="0" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="VerticalContentAlignment"
                    Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="PillBorder"
                                Background="Transparent"
                                BorderBrush="#1A237E"
                                BorderThickness="1.5,1.5,0.75,1.5"
                                CornerRadius="22.5,0,0,22.5"
                                Cursor="Hand">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="PillBorder"
                                        Property="Background"
                                        Value="#1A237E" />
                                <Setter Property="Foreground"
                                        Value="White" />
                                <Setter Property="Panel.ZIndex"
                                        Value="1" />
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="False">
                                <Setter TargetName="PillBorder"
                                        Property="Background"
                                        Value="Transparent" />
                                <Setter Property="Foreground"
                                        Value="#1A237E" />
                                <Setter Property="Panel.ZIndex"
                                        Value="0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentedMiddleTabStyle"
               TargetType="TabItem">
            <Setter Property="MinHeight"
                    Value="45" />
            <Setter Property="Margin"
                    Value="0" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="VerticalContentAlignment"
                    Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="PillBorder"
                                Background="Transparent"
                                BorderBrush="#1A237E"
                                BorderThickness="0.75,1.5,0.75,1.5"
                                CornerRadius="0"
                                Cursor="Hand">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="PillBorder"
                                        Property="Background"
                                        Value="#1A237E" />
                                <Setter Property="Foreground"
                                        Value="White" />
                                <Setter Property="Panel.ZIndex"
                                        Value="1" />
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="False">
                                <Setter TargetName="PillBorder"
                                        Property="Background"
                                        Value="Transparent" />
                                <Setter Property="Foreground"
                                        Value="#1A237E" />
                                <Setter Property="Panel.ZIndex"
                                        Value="0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentedRightTabStyle"
               TargetType="TabItem">
            <Setter Property="MinHeight"
                    Value="45" />
            <Setter Property="Margin"
                    Value="0" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="VerticalContentAlignment"
                    Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="PillBorder"
                                Background="Transparent"
                                BorderBrush="#1A237E"
                                BorderThickness="0.75,1.5,1.5,1.5"
                                CornerRadius="0,22.5,22.5,0"
                                Cursor="Hand">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="PillBorder"
                                        Property="Background"
                                        Value="#1A237E" />
                                <Setter Property="Foreground"
                                        Value="White" />
                                <Setter Property="Panel.ZIndex"
                                        Value="1" />
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="False">
                                <Setter TargetName="PillBorder"
                                        Property="Background"
                                        Value="Transparent" />
                                <Setter Property="Foreground"
                                        Value="#1A237E" />
                                <Setter Property="Panel.ZIndex"
                                        Value="0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Bảng điều khiển Lớp chủ nhiệm"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1A237E" />
                <TextBlock Text="{Binding ClassTitle}"
                           FontSize="15"
                           Foreground="#878A99"
                           Margin="0,5,0,0"
                           FontWeight="SemiBold" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <StackPanel Orientation="Vertical"
                            Margin="0,0,20,0">
                    <TextBlock Text="Năm học:"
                               Foreground="Black"
                               FontWeight="Bold"
                               FontSize="15"
                               Margin="5,0,0,5" />
                    <ComboBox SelectedValue="{Binding CurrentAcademicYear}"
                              SelectedValuePath="Content"
                              Width="130"
                              Height="42"
                              FontSize="15"
                              VerticalContentAlignment="Center"
                              FontWeight="SemiBold">
                        <ComboBoxItem Content="2025-2026" />
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Học kỳ:"
                               Foreground="Black"
                               FontWeight="Bold"
                               FontSize="15"
                               Margin="5,0,0,5" />
                    <ComboBox SelectedValue="{Binding CurrentSemester}"
                              SelectedValuePath="Content"
                              Width="120"
                              Height="42"
                              FontSize="15"
                              VerticalContentAlignment="Center"
                              FontWeight="SemiBold">
                        <ComboBoxItem Content="Học kỳ 1" />
                        <ComboBoxItem Content="Học kỳ 2" />
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    SelectedIndex="0"
                    VerticalContentAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
            <TabControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1"
                                 Columns="3" />
                </ItemsPanelTemplate>
            </TabControl.ItemsPanel>

            <TabItem Style="{StaticResource SegmentedLeftTabStyle}">
                <TabItem.Header>
                    <TextBlock Text="Danh sách học sinh"
                               FontSize="17"
                               FontWeight="SemiBold" />
                </TabItem.Header>
                <components:HomeroomStudentListUC DataContext="{Binding}"
                                              VerticalAlignment="Stretch"
                                              HorizontalAlignment="Stretch"
                                              Margin="0,20,0,0" />
            </TabItem>

            <TabItem Style="{StaticResource SegmentedMiddleTabStyle}">
                <TabItem.Header>
                    <TextBlock Text="Bảng điểm"
                               FontSize="17"
                               FontWeight="SemiBold" />
                </TabItem.Header>
                <components:AcademicConductUC DataContext="{Binding}"
                                              VerticalAlignment="Stretch"
                                              HorizontalAlignment="Stretch"
                                              Margin="0,20,0,0" />
            </TabItem>

            <TabItem Style="{StaticResource SegmentedRightTabStyle}">
                <TabItem.Header>
                    <TextBlock Text="Tổng kết học kỳ"
                               FontSize="17"
                               FontWeight="SemiBold" />
                </TabItem.Header>
                <components:TermSummaryUC DataContext="{Binding}"
                                          VerticalAlignment="Stretch"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,20,0,0" />
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>