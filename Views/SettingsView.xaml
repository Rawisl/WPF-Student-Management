<UserControl x:Class="WPF_Student_Management.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#F5F6FA">

    <UserControl.DataContext>
        <viewmodels:SettingsViewModel />
    </UserControl.DataContext>

    <Grid Margin="30">
        <materialDesign:Card UniformCornerRadius="12" Padding="40,30" MaxWidth="450" HorizontalAlignment="Center" VerticalAlignment="Top">
            <StackPanel>
                <materialDesign:PackIcon Kind="ShieldLockOutline" Width="55" Height="55" Foreground="#2962FF" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="ĐỔI MẬT KHẨU" FontSize="22" FontWeight="Bold" Foreground="#1A237E" HorizontalAlignment="Center"/>

                <TextBlock Text="Thay đổi mật khẩu định kỳ giúp bảo vệ tài khoản của bạn tốt hơn khỏi các rủi ro." 
                           TextWrapping="Wrap" TextAlignment="Center" FontSize="14" Foreground="#878A99" Margin="0,10,0,25"/>

                <TextBox Text="{Binding OldPassword, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Mật khẩu hiện tại" 
                         FontFamily="Password"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         Margin="0,0,0,20" FontSize="15"/>

                <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Mật khẩu mới (ít nhất 6 ký tự)" 
                         FontFamily="Password"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         Margin="0,0,0,20" FontSize="15"/>

                <TextBox Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Xác nhận mật khẩu mới" 
                         FontFamily="Password"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         Margin="0,0,0,35" FontSize="15"/>

                <Button Content="CẬP NHẬT MẬT KHẨU" 
                        Command="{Binding ChangePasswordCommand}" 
                        Style="{StaticResource PrimaryRoundedButton}" 
                        Height="45" FontSize="16" FontWeight="Bold" Cursor="Hand"
                        IsDefault="True"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>