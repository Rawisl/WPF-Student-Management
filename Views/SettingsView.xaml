<UserControl x:Class="WPF_Student_Management.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="800"
             Background="#F5F6FA">

    <UserControl.DataContext>
        <viewmodels:SettingsViewModel />
    </UserControl.DataContext>

    <Grid Margin="30">
        <materialDesign:Card UniformCornerRadius="12" Padding="30" MaxWidth="500" HorizontalAlignment="Center" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="ĐỔI MẬT KHẨU" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,25" HorizontalAlignment="Center"/>

                <TextBox Text="{Binding OldPassword, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Mật khẩu hiện tại" 
                         FontFamily="Password"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         Margin="0,0,0,20" FontSize="15"/>

                <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Mật khẩu mới" 
                         FontFamily="Password"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         Margin="0,0,0,20" FontSize="15"/>

                <TextBox Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Xác nhận mật khẩu mới" 
                         FontFamily="Password"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         Margin="0,0,0,30" FontSize="15"/>

                <Button Content="CẬP NHẬT MẬT KHẨU" 
                        Command="{Binding ChangePasswordCommand}" 
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                        Style="{StaticResource MaterialDesignRaisedButton}" 
                        Height="40" FontSize="15" Cursor="Hand"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>