<UserControl x:Class="WPF_Student_Management.Views.EmployeeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:WPF_Student_Management.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="1100">

    <UserControl.DataContext>
        <viewmodels:EmployeeManagementViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center">
                <TextBlock Text="Danh sách nhân viên"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1A237E" />
                <TextBlock Text="Quản lý thông tin Giáo viên và Cán bộ nhân viên"
                           FontSize="14"
                           Foreground="#878A99"
                           Margin="0,5,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Command="{Binding OpenAddDialogCommand}"
                        Height="42"
                        Padding="15,0,15,0"
                        Style="{StaticResource PrimaryRoundedButton}"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="PlusBoxOutline"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Tiếp nhận nhân viên"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Color="#DDDDDD"
                                  Opacity="0.5" />
            </Border.Effect>

            <DataGrid ItemsSource="{Binding StaffList}"
                      IsReadOnly="True"
                      Style="{StaticResource GlobalDataGridStyle}"
                      CellStyle="{StaticResource GlobalDataGridCellStyle}">
                
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã NV"
                                        Binding="{Binding StaffId}"
                                        Width="80"
                                        IsReadOnly="True"
                                        HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                        ElementStyle="{StaticResource GlobalCenterElementStyle}" />
                    <DataGridTextColumn Header="Họ và Tên"
                                        Binding="{Binding FullName}"
                                        Width="*"
                                        IsReadOnly="True"
                                        HeaderStyle="{StaticResource GlobalLeftHeaderStyle}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"
                                   BasedOn="{StaticResource GlobalLeftElementStyle}">
                                <Setter Property="FontWeight"
                                        Value="SemiBold" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>

                    </DataGridTextColumn>
                    
                    <DataGridTextColumn Header="Giới tính"
                                        Binding="{Binding Gender}"
                                        Width="100"
                                        IsReadOnly="True"
                                        HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                        ElementStyle="{StaticResource GlobalCenterElementStyle}" />
                    <DataGridTextColumn Header="Chuyên môn"
                                        Binding="{Binding Specialization}"
                                        Width="180"
                                        IsReadOnly="True"
                                        HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                        ElementStyle="{StaticResource GlobalCenterElementStyle}" />
                    <DataGridTextColumn Header="SĐT"
                                        Binding="{Binding PhoneNumber}"
                                        Width="130"
                                        IsReadOnly="True"
                                        HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                        ElementStyle="{StaticResource GlobalCenterElementStyle}" 
                                        FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Trạng thái"
                                        Binding="{Binding Status}"
                                        Width="100"
                                        IsReadOnly="True"
                                        HeaderStyle="{StaticResource GlobalCenterHeaderStyle}"
                                        ElementStyle="{StaticResource GlobalCenterElementStyle}" />

                    <DataGridTemplateColumn Header="Hành động"
                                            Width="120"
                                            HeaderStyle="{StaticResource GlobalCenterHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">

                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility"
                                                    Value="Hidden" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                                                             Value="True">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Chỉnh sửa"
                                            Width="35"
                                            Height="35"
                                            Foreground="#00B894"
                                            Background="Transparent"
                                            Cursor="Hand">
                                        <materialDesign:PackIcon Kind="PencilOutline" />
                                    </Button>

                                    <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Xóa"
                                            Width="35"
                                            Height="35"
                                            Foreground="#FF4757"
                                            Background="Transparent"
                                            Cursor="Hand"
                                            Margin="5,0,0,0">
                                        <materialDesign:PackIcon Kind="TrashCanOutline" />
                                    </Button>

                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>